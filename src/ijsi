cmd_check() {
  printf '%sijsi%s %s\n\n' "$C_BOLD" "$C_RESET" "$IJSI_VERSION"

  printf 'Config file:\n  %s%s\n\n' "$CONFIG_FILE" \
    "$([[ -f "$CONFIG_FILE" ]] && echo "" || echo "  (not created yet)")"

  printf 'Tools:\n'
  printf '  indexer CLI:  %s\n' "$(have_cli && command -v "$CLI" || echo "not found: $CLI")"
  printf '  composer:     %s\n' "$(have_composer && command -v "$COMPOSER" || echo "not found: $COMPOSER")"
  printf '  gh (for PRs): %s\n' "$(have_gh && command -v gh || echo "not found (intellij.yaml PRs disabled)")"
  printf '  flock:        %s\n' "$(command -v flock 2>/dev/null || echo "not found (refresh runs without a lock)")"
  printf '  terminal GUI: %s\n\n' "$(detect_tui_name)"

  printf 'PhpStorm:\n  %s\n\n' "${PHPSTORM_HOME:-not found (set PHPSTORM_IDE)}"

  printf 'Repositories:\n'
  if [[ -d "$REPOS_DIR" ]]; then printf '  folder:  %s  (found)\n' "$REPOS_DIR"; else printf '  folder:  %s  (MISSING)\n' "$REPOS_DIR"; fi
  printf '  repos discovered: %s\n' "$(count_repos)"
  printf '  branch tracked:   %s\n' "${DEFAULT_BRANCH:-auto (origin/HEAD)}"
  printf '  intellij.yaml:    %s\n\n' "$INTELLIJ_YAML_VCS"

  printf 'Hosting (MinIO):\n'
  printf '  public base-url:  %s\n' "$(s3_public_base_url)"
  printf '  mc client:        %s\n' "$(have_mc && command -v "$MC" || echo "NOT FOUND: $MC")"
  printf '  mc alias %-9s %s\n' "$S3_ALIAS:" "$(mc_alias_label)"
  printf '  upload target:    %s\n' "$(s3_target)"
  s3_preflight >/dev/null && printf '  readiness:        READY\n' || printf '  readiness:        NOT READY (see: ijsi s3 status)\n'
  printf '\n'

  printf 'Cache:  %s\n' "$CACHE_DIR"
}

cmd_list() {
  iter_repos | while read -r repo; do
    local head
    head="$(git -C "$repo" rev-parse --short HEAD 2>/dev/null || echo "-------")"
    printf '%-40s %-16s %s\n' "$(basename "$repo")" "$(repo_default_branch "$repo")@$head" "$repo"
  done
}

cmd_logs() {
  local f
  f="$(ls -1t "$LOG_DIR"/*.log 2>/dev/null | head -1)"
  if [[ -z "$f" ]]; then echo "No logs in $LOG_DIR yet. Run: ijsi refresh"; return 0; fi
  echo "Newest log: $f"
  echo "----------------------------------------"
  cat "$f"
}

cmd_reset_state() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    rm -f "$STATE_DIR"/*.sha256 2>/dev/null
    echo "State reset. Next refresh will recheck all repos."; return 0
  fi
  local repo repo_id
  repo="$(resolve_repo_arg "$target")" || { echo "No matching repo for: $target" >&2; return 1; }
  repo_id="$(repo_id_for "$repo")"
  rm -f "$STATE_DIR/${repo_id}.sha256"
  echo "State reset for: $repo  (next refresh will re-index it)."
}

cmd_clear_cache() {
  rm -rf "$CACHE_DIR"; ensure_dirs
  echo "Cache cleared: $CACHE_DIR"
}

cmd_prune_logs() {
  local keep="${1:-100}" removed
  if ! [[ "$keep" =~ ^[0-9]+$ ]]; then echo "prune-logs: keep must be a non-negative integer" >&2; return 1; fi
  removed="$(ls -1t "$LOG_DIR"/*.log 2>/dev/null | tail -n +"$((keep + 1))" | wc -l | tr -d ' ')"
  ls -1t "$LOG_DIR"/*.log 2>/dev/null | tail -n +"$((keep + 1))" | xargs -r rm -f
  echo "Pruned ${removed:-0} old log file(s); kept newest $keep."
}

cmd_config() {
  case "${1:-show}" in
    show|"")  print_resolved_config ;;
    path)     printf '%s\n' "$CONFIG_FILE" ;;
    init)     save_config; echo "Wrote $CONFIG_FILE" ;;
    edit)     save_config_if_missing; "${EDITOR:-vi}" "$CONFIG_FILE" ;;
    *)        echo "config: unknown subcommand: $1" >&2
              echo "usage: ijsi config [show|path|init|edit]" >&2; return 1 ;;
  esac
}

print_resolved_config() {
  printf 'config file:        %s\n' "$CONFIG_FILE"
  printf 'REPOS_DIR:          %s\n' "$REPOS_DIR"
  printf 'CACHE_DIR:          %s\n' "$CACHE_DIR"
  printf 'CLI:                %s\n' "$CLI"
  printf 'MC:                 %s\n' "$MC"
  printf 'COMPOSER:           %s\n' "$COMPOSER"
  printf 'TOOLBOX_APPS:       %s\n' "$TOOLBOX_APPS"
  printf 'PHPSTORM_IDE:       %s  ->  %s\n' "$PHPSTORM_IDE" "${PHPSTORM_HOME:-<none>}"
  printf 'DEFAULT_BRANCH:     %s\n' "${DEFAULT_BRANCH:-<auto>}"
  printf 'INTELLIJ_YAML_VCS:  %s\n' "$INTELLIJ_YAML_VCS"
  printf 'S3_ALIAS:           %s  (%s)\n' "$S3_ALIAS" "$(mc_alias_label)"
  printf 'S3_ENDPOINT:        %s\n' "${S3_ENDPOINT:-<unset>}"
  printf 'S3_BUCKET:          %s\n' "${S3_BUCKET:-<unset>}"
  printf 'S3_PREFIX:          %s\n' "${S3_PREFIX:-<none>}"
  printf 'PUBLIC_BASE_URL:    %s\n' "${PUBLIC_BASE_URL:-<auto>}"
  printf 'public base-url:    %s\n' "$(s3_public_base_url)"
}

# ===========================================================================
# Terminal GUI (whiptail / dialog) - slimmed
# ===========================================================================

TUI=""
detect_tui() {
  if   command -v whiptail >/dev/null 2>&1; then TUI=whiptail
  elif command -v dialog   >/dev/null 2>&1; then TUI=dialog
  else TUI=""; fi
}
detect_tui_name() {
  detect_tui
  [[ -n "$TUI" ]] && command -v "$TUI" || echo "none (install 'whiptail' or 'dialog')"
}

# whiptail/dialog wrappers. Both write the chosen value to stderr; the
# 3>&1 1>&2 2>&3 dance moves it to stdout so we can capture it.
tui_menu()     { local t="$1" x="$2"; shift 2; "$TUI" --title "$t" --menu       "$x" 21 86 12 "$@" 3>&1 1>&2 2>&3; }
tui_input()    { local t="$1" x="$2" d="$3";   "$TUI" --title "$t" --inputbox    "$x" 10 86 "$d" 3>&1 1>&2 2>&3; }
tui_password() { local t="$1" x="$2";          "$TUI" --title "$t" --passwordbox "$x" 10 86 3>&1 1>&2 2>&3; }
tui_yesno()    { local t="$1" x="$2";          "$TUI" --title "$t" --yesno       "$x" 12 86; }
tui_msg()      { local t="$1" x="$2";          "$TUI" --title "$t" --msgbox       "$x" 18 86; }
tui_textbox()  { local t="$1" f="$2";          "$TUI" --title "$t" --textbox      "$f" 26 100; }

# Run a refresh (optionally forced / filtered) and show the result in a textbox.
tui_run_refresh() {
  local force="$1" only="$2"
  local out; out="$(mktemp "${TMPDIR:-/tmp}/ijsi.XXXXXX")"
  clear
  echo "Running refresh: update -> composer install -> index -> upload ..."
  echo
  # No colours into the captured file.
  (
    C_RESET= ; C_BOLD= ; C_DIM= ; C_GREEN= ; C_YELLOW= ; C_RED= ; C_BLUE=
    cmd_refresh ${force:+--force} ${only:+--only "$only"}
  ) 2>&1 | tee "$out"
  tui_textbox "Refresh result" "$out"
  rm -f "$out"
}

tui_minio_menu() {
  local choice v out
  while true; do
    choice="$(tui_menu "MinIO / S3" "Alias: $(mc_alias_label)   Bucket: ${S3_BUCKET:-<unset>}   URL: $(s3_public_base_url)" \
      login    "Set credentials (endpoint + keys)" \
      setup    "Create bucket + grant public download" \
      test     "Test the connection" \
      endpoint "Set endpoint URL" \
      bucket   "Set bucket name" \
      prefix   "Set prefix (optional)" \
      url      "Set public base URL override (optional)" \
      status   "Show MinIO status" \
      back     "Back")" || return
    case "$choice" in
      login)    clear; cmd_s3_login; echo; read -r -p "Press Enter..." _ ;;
      setup)    clear; cmd_s3_setup; echo; read -r -p "Press Enter..." _ ;;
      test)     clear; cmd_s3_test;  echo; read -r -p "Press Enter..." _ ;;
      endpoint) v="$(tui_input "Endpoint" "S3 endpoint URL:" "$S3_ENDPOINT")" && { S3_ENDPOINT="$v"; save_config; BASE_URL="$(s3_public_base_url)"; } ;;
      bucket)   v="$(tui_input "Bucket" "Bucket name:" "$S3_BUCKET")" && { S3_BUCKET="$v"; save_config; BASE_URL="$(s3_public_base_url)"; } ;;
      prefix)   v="$(tui_input "Prefix" "Object key prefix (blank = none):" "$S3_PREFIX")" && { S3_PREFIX="$v"; save_config; BASE_URL="$(s3_public_base_url)"; } ;;
      url)      v="$(tui_input "Public URL" "Override public base URL (blank = derive):" "$PUBLIC_BASE_URL")" && { PUBLIC_BASE_URL="$v"; save_config; BASE_URL="$(s3_public_base_url)"; } ;;
      status)   out="$(mktemp "${TMPDIR:-/tmp}/ijsi.XXXXXX")"; s3_status > "$out" 2>&1; tui_textbox "MinIO status" "$out"; rm -f "$out" ;;
      back|*)   return ;;
    esac
  done
}

tui_config_menu() {
  local choice v out
  while true; do
    choice="$(tui_menu "Configure" "Repos: $REPOS_DIR   PhpStorm: ${PHPSTORM_HOME:-<none>}" \
      repos    "Repos folder              ($REPOS_DIR)" \
      phpstorm "PhpStorm install dir      ($PHPSTORM_IDE)" \
      branch   "Branch to track           (${DEFAULT_BRANCH:-auto})" \
      yaml     "intellij.yaml VCS mode    ($INTELLIJ_YAML_VCS)" \
      cli      "Indexer CLI               ($CLI)" \
      composer "Composer command          ($COMPOSER)" \
      mc       "mc command                ($MC)" \
      show     "Show resolved config" \
      back     "Back")" || return
    case "$choice" in
      repos)    v="$(tui_input "Repos folder" "Folder containing your forked API repos:" "$REPOS_DIR")" && { REPOS_DIR="$v"; save_config; } ;;
      phpstorm) v="$(tui_input "PhpStorm" "Install dir, or 'auto' to detect:" "$PHPSTORM_IDE")" && { PHPSTORM_IDE="$v"; save_config; PHPSTORM_HOME="$(resolve_phpstorm "$PHPSTORM_IDE")"; } ;;
      branch)   v="$(tui_input "Branch" "Branch to track (blank = auto-detect):" "$DEFAULT_BRANCH")" && { DEFAULT_BRANCH="$v"; save_config; } ;;
      yaml)     v="$(tui_menu "intellij.yaml VCS" "How should ijsi land intellij.yaml?" pr "Open a PR per repo" leave "Write only (you commit)" off "Do not touch git")" && { INTELLIJ_YAML_VCS="$v"; save_config; } ;;
      cli)      v="$(tui_input "Indexer CLI" "ij-shared-indexes-tool-cli command or path:" "$CLI")" && { CLI="$v"; save_config; } ;;
      composer) v="$(tui_input "Composer" "composer command or path:" "$COMPOSER")" && { COMPOSER="$v"; save_config; } ;;
      mc)       v="$(tui_input "mc" "MinIO client command or path:" "$MC")" && { MC="$v"; save_config; } ;;
      show)     out="$(mktemp "${TMPDIR:-/tmp}/ijsi.XXXXXX")"; print_resolved_config > "$out"; tui_textbox "Resolved config" "$out"; rm -f "$out" ;;
      back|*)   return ;;
    esac
  done
}

tui_maint_menu() {
  local choice out
  while true; do
    choice="$(tui_menu "Maintenance" "Cache: $CACHE_DIR" \
      reset "Reset state (recheck all repos next refresh)" \
      sync  "Re-upload local indexes to MinIO" \
      prune "Prune old logs (keep newest 100)" \
      clear "Clear the entire cache" \
      back  "Back")" || return
    case "$choice" in
      reset) tui_yesno "Reset state" "Forget all index fingerprints?\nNext refresh re-checks every repo." && { cmd_reset_state >/dev/null; tui_msg "Done" "State reset."; } ;;
      sync)  out="$(mktemp "${TMPDIR:-/tmp}/ijsi.XXXXXX")"; s3_publish > "$out" 2>&1 && rm -f "$STATE_DIR/.needs_upload"; tui_textbox "Re-upload to MinIO" "$out"; rm -f "$out" ;;
      prune) out="$(mktemp "${TMPDIR:-/tmp}/ijsi.XXXXXX")"; cmd_prune_logs 100 > "$out" 2>&1; tui_textbox "Prune logs" "$out"; rm -f "$out" ;;
      clear) tui_yesno "Clear cache" "Delete $CACHE_DIR entirely?\nAll generated indexes and state are removed." && { cmd_clear_cache >/dev/null; tui_msg "Done" "Cache cleared."; } ;;
      back|*) return ;;
    esac
  done
}

tui_main() {
  detect_tui
  if [[ -z "$TUI" ]]; then
    echo "The terminal GUI needs 'whiptail' (package: newt) or 'dialog'." >&2
    echo "Install one, e.g.:  sudo pacman -S newt   (or: sudo apt install whiptail)" >&2
    echo >&2; usage; return 1
  fi

  ensure_dirs
  save_config_if_missing

  local choice header v out
  while true; do
    header="$(printf 'JetBrains shared-index manager for PHP API forks (v%s)\n\nRepos: %s in %s\nMinIO: %s    URL: %s\n\nChoose an action:' \
      "$IJSI_VERSION" "$(count_repos)" "$REPOS_DIR" "$(mc_alias_label)" "$(s3_public_base_url)")"

    choice="$(tui_menu "ijsi" "$header" \
      refresh "Update + index changed repos, then upload" \
      force   "Force re-index ALL repos (ignore cache)" \
      only    "Index specific repos by name" \
      minio   "MinIO / S3 settings & credentials" \
      config  "Configure repos folder, PhpStorm, paths" \
      status  "Status & health check" \
      logs    "View newest log" \
      maint   "Maintenance (reset / prune / clear)" \
      quit    "Quit")" || break

    case "$choice" in
      refresh) tui_run_refresh "" "" ;;
      force)   tui_yesno "Force re-index" "Re-index ALL repos, ignoring the cache?\nThis can take a while." && tui_run_refresh "1" "" ;;
      only)    v="$(tui_input "Index specific repos" "Comma-separated repo names:" "")" && [[ -n "$v" ]] && tui_run_refresh "" "$v" ;;
      minio)   tui_minio_menu ;;
      config)  tui_config_menu ;;
      status)  out="$(mktemp "${TMPDIR:-/tmp}/ijsi.XXXXXX")"; cmd_check > "$out" 2>&1; tui_textbox "Status" "$out"; rm -f "$out" ;;
      logs)    out="$(mktemp "${TMPDIR:-/tmp}/ijsi.XXXXXX")"; cmd_logs > "$out" 2>&1; tui_textbox "Newest log" "$out"; rm -f "$out" ;;
      maint)   tui_maint_menu ;;
      quit|*)  break ;;
    esac
  done
  clear 2>/dev/null || true
}

# ===========================================================================
# CLI dispatch
# ===========================================================================

usage() {
  cat <<EOF
ijsi $IJSI_VERSION - JetBrains shared-index manager for PHP API forks

Indexes a folder of forked PHP/Laravel repos (PhpStorm) and uploads the shared
indexes to MinIO so the whole team skips analysing the project and its vendor/
dependencies. Run with no arguments for the TUI.

USAGE
  ijsi                         Open the terminal GUI
  ijsi refresh [opts]          Update + index changed repos, then upload
                                 --force, -f       re-index everything
                                 --only a,b,...    only repos matching these names
                                 --no-upload       index locally, skip the upload
  ijsi s3 [sub]                MinIO: status | login | setup | sync | test
  ijsi config [sub]            Config: show | path | init | edit
  ijsi list                    List discovered repos
  ijsi logs                    Show the newest run log
  ijsi reset-state [name]      Forget fingerprints (all, or one repo)
  ijsi prune-logs [keep]       Delete old logs, keep newest <keep> (default 100)
  ijsi clear-cache             Remove the whole cache directory
  ijsi check | doctor          Detected tools, PhpStorm, repos, MinIO readiness
  ijsi version                 Print version
  ijsi help                    This help

QUICK START
  1) ijsi config edit           # set REPOS_DIR (your folder of forks) + bucket
  2) ijsi s3 login              # endpoint + access/secret -> stored in mc
  3) ijsi s3 setup              # create bucket + grant anonymous download
  4) ijsi refresh               # update, composer install, index, upload
                                #   -> review & merge each "intellij.yaml fix" PR

CONFIG
  $CONFIG_FILE
  Key vars: REPOS_DIR, PHPSTORM_IDE, DEFAULT_BRANCH, INTELLIJ_YAML_VCS,
            S3_ALIAS/ENDPOINT/BUCKET/PREFIX, PUBLIC_BASE_URL.
  Any IJSI_<VAR> environment variable overrides the config file.
EOF
}

main() {
  load_config
  apply_env_and_defaults

  local cmd="${1:-}"; [[ $# -gt 0 ]] && shift
  case "$cmd" in
    "")                   tui_main ;;
    tui|menu|ui)          tui_main ;;
    refresh)              ensure_dirs; cmd_refresh "$@" ;;
    s3)                   ensure_dirs; cmd_s3 "$@" ;;
    config)               cmd_config "$@" ;;
    list)                 cmd_list ;;
    logs)                 cmd_logs ;;
    reset-state)          ensure_dirs; cmd_reset_state "$@" ;;
    prune-logs)           cmd_prune_logs "$@" ;;
    clear-cache)          cmd_clear_cache ;;
    check|doctor)         cmd_check ;;
    version|-V|--version) echo "ijsi $IJSI_VERSION" ;;
    help|-h|--help)       usage ;;
    *)                    echo "ijsi: unknown command: $cmd" >&2; echo >&2; usage; exit 1 ;;
  esac
}

# Only run when executed directly (allows sourcing for tests/reuse).
if [[ "${BASH_SOURCE[0]:-$0}" == "${0}" ]]; then
  main "$@"
fi
