#!/usr/bin/env bash
#
# ijsi - JetBrains shared-index manager
#
# Generates JetBrains "shared indexes" for your projects so that opening one in
# PhpStorm / WebStorm / GoLand / DataGrip reuses a prebuilt index instead of
# analysing from scratch. Indexes are uploaded to a MinIO (S3-compatible) bucket
# and each project gets an intellij.yaml pointing the IDE at that bucket, so the
# whole team downloads the same indexes.
#
# Hosting model:
#   * MinIO/S3 (default once configured): `refresh` generates indexes and uploads
#     only the changed files with `mc mirror`. Each project's intellij.yaml is
#     written with the bucket's PUBLIC base-url, so it is correct to commit to VCS.
#   * Local test server (fallback): with upload disabled, indexes are served from
#     http://127.0.0.1:<port> via `ijsi server` for trying things out locally.
#
# Reindexing is on demand: run `ijsi refresh` (or the TUI). There is no timer.
#
# Credentials live in mc's own store (`mc alias set` -> ~/.mc/config.json, mode
# 0600). ijsi never writes the secret key to its own config file.
#
# Run with no arguments to open the TUI. Run `ijsi help` for the CLI.

set -uo pipefail

IJSI_VERSION="3.0.0"

SELF="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"

# ---------------------------------------------------------------------------
# Configuration (defaults < config file < IJSI_* environment overrides)
# ---------------------------------------------------------------------------

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/ijsi"
CONFIG_FILE="${IJSI_CONFIG:-$CONFIG_HOME/config}"

DEFAULT_PORT=25561
DEFAULT_CACHE_DIR="$HOME/.cache/ij-shared-indexes"
DEFAULT_TOOLBOX_APPS="$HOME/.local/share/JetBrains/Toolbox/apps"
DEFAULT_S3_ALIAS="ijsi"
DEFAULT_PROJECT_ROOTS=(
  "$HOME/PhpstormProjects"
  "$HOME/WebstormProjects"
  "$HOME/GoLandProjects"
  "$HOME/DatagripProjects"
)

# Set by the config file if present; left empty here so env/defaults can win.
PORT="" ; CACHE_DIR="" ; CLI="" ; MC="" ; TOOLBOX_APPS=""
PHPSTORM_IDE="" ; WEBSTORM_IDE="" ; DATAGRIP_IDE="" ; GOLAND_IDE=""
PROJECT_ROOTS=()
EXTRA_PROJECTS=()

# MinIO / S3 upload (no secrets here - those live in mc's alias store).
S3_ENABLED="" ; S3_ALIAS="" ; S3_ENDPOINT="" ; S3_BUCKET="" ; S3_PREFIX="" ; PUBLIC_BASE_URL=""

load_config() {
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
  fi
}

apply_env_and_defaults() {
  CLI="${IJSI_CLI:-${CLI:-ij-shared-indexes-tool-cli}}"
  MC="${IJSI_MC:-${MC:-mc}}"
  PORT="${IJSI_PORT:-${PORT:-$DEFAULT_PORT}}"
  CACHE_DIR="${IJSI_CACHE_DIR:-${CACHE_DIR:-$DEFAULT_CACHE_DIR}}"
  TOOLBOX_APPS="${IJSI_TOOLBOX_APPS:-${TOOLBOX_APPS:-$DEFAULT_TOOLBOX_APPS}}"

  S3_ENABLED="${IJSI_S3_ENABLED:-${S3_ENABLED:-no}}"
  S3_ALIAS="${IJSI_S3_ALIAS:-${S3_ALIAS:-$DEFAULT_S3_ALIAS}}"
  S3_ENDPOINT="${IJSI_S3_ENDPOINT:-${S3_ENDPOINT:-}}"
  S3_BUCKET="${IJSI_S3_BUCKET:-${S3_BUCKET:-}}"
  S3_PREFIX="${IJSI_S3_PREFIX:-${S3_PREFIX:-}}"
  PUBLIC_BASE_URL="${IJSI_PUBLIC_BASE_URL:-${PUBLIC_BASE_URL:-}}"

  DATA_DIR="$CACHE_DIR/tool-data"
  STATE_DIR="$CACHE_DIR/state"
  LOG_DIR="$CACHE_DIR/logs"
  CONFIG_DIR="$CACHE_DIR/configs"
  SYSTEMD_DIR="$HOME/.config/systemd/user"

  if [[ ${#PROJECT_ROOTS[@]} -eq 0 ]]; then
    PROJECT_ROOTS=( "${DEFAULT_PROJECT_ROOTS[@]}" )
  fi

  # Raw IDE settings: "auto" (detect) or an absolute install dir.
  PHPSTORM_IDE="${IJSI_PHPSTORM_IDE:-${PHPSTORM_IDE:-auto}}"
  WEBSTORM_IDE="${IJSI_WEBSTORM_IDE:-${WEBSTORM_IDE:-auto}}"
  DATAGRIP_IDE="${IJSI_DATAGRIP_IDE:-${DATAGRIP_IDE:-auto}}"
  GOLAND_IDE="${IJSI_GOLAND_IDE:-${GOLAND_IDE:-auto}}"

  # Resolved install dirs actually passed to the CLI.
  PHPSTORM_HOME="$(resolve_ide "$PHPSTORM_IDE" phpstorm.sh)"
  WEBSTORM_HOME="$(resolve_ide "$WEBSTORM_IDE" webstorm.sh)"
  DATAGRIP_HOME="$(resolve_ide "$DATAGRIP_IDE" datagrip.sh)"
  GOLAND_HOME="$(resolve_ide "$GOLAND_IDE" goland.sh)"

  # The base-url baked into intellij.yaml and passed to the CLI when generating.
  BASE_URL="$(effective_base_url)"
}

resolve_ide() {
  local configured="$1" launcher="$2"

  if [[ -n "$configured" && "$configured" != "auto" ]]; then
    printf '%s' "$configured"
    return 0
  fi

  local r found=""
  for r in "$TOOLBOX_APPS" "$HOME/.local/share/JetBrains" "/opt"; do
    [[ -d "$r" ]] || continue
    found="$(find "$r" -maxdepth 8 -type f -name "$launcher" 2>/dev/null | sort -V | tail -n 1)"
    if [[ -n "$found" ]]; then
      printf '%s' "$(dirname "$(dirname "$found")")"
      return 0
    fi
  done
  printf ''
}

# ---------------------------------------------------------------------------
# Base-url / S3 target helpers
# ---------------------------------------------------------------------------

# Public download URL the IDE uses. Explicit PUBLIC_BASE_URL wins (e.g. a CDN or
# reverse proxy); otherwise derive it from endpoint + bucket + prefix.
s3_public_base_url() {
  if [[ -n "$PUBLIC_BASE_URL" ]]; then
    printf '%s' "${PUBLIC_BASE_URL%/}"
    return
  fi
  local u="${S3_ENDPOINT%/}"
  [[ -n "$S3_BUCKET" ]] && u="$u/$S3_BUCKET"
  [[ -n "$S3_PREFIX" ]] && u="$u/${S3_PREFIX#/}"
  printf '%s' "$u"
}

# Where index files are uploaded with mc:  <alias>/<bucket>[/<prefix>]
s3_target() {
  local t="$S3_ALIAS/$S3_BUCKET"
  [[ -n "$S3_PREFIX" ]] && t="$t/${S3_PREFIX#/}"
  printf '%s' "$t"
}

# The base-url actually used when generating indexes: the public bucket URL when
# uploading is on, otherwise the local test server.
effective_base_url() {
  if [[ "$S3_ENABLED" == "yes" ]]; then
    s3_public_base_url
  else
    printf 'http://127.0.0.1:%s' "$PORT"
  fi
}

ensure_dirs() {
  mkdir -p "$CONFIG_HOME" "$DATA_DIR" "$STATE_DIR" "$LOG_DIR" "$CONFIG_DIR"
}

save_config() {
  mkdir -p "$CONFIG_HOME"
  # Write under a tight umask so the file is never momentarily world-readable.
  local oldmask; oldmask="$(umask)"
  umask 077
  {
    printf '# ijsi configuration  -  sourced as bash. IJSI_* env vars override these.\n'
    printf '# Edit by hand, or via:  ijsi  ->  Configure / MinIO settings.\n'
    printf '# NOTE: S3 credentials are NOT stored here; they live in mc (~/.mc/config.json).\n\n'
    printf 'PORT=%q\n' "$PORT"
    printf 'CACHE_DIR=%q\n' "$CACHE_DIR"
    printf 'CLI=%q\n' "$CLI"
    printf 'MC=%q\n' "$MC"
    printf 'TOOLBOX_APPS=%q\n\n' "$TOOLBOX_APPS"
    printf '# MinIO / S3 upload (mc alias holds the access/secret keys).\n'
    printf 'S3_ENABLED=%q\n' "$S3_ENABLED"
    printf 'S3_ALIAS=%q\n' "$S3_ALIAS"
    printf 'S3_ENDPOINT=%q\n' "$S3_ENDPOINT"
    printf 'S3_BUCKET=%q\n' "$S3_BUCKET"
    printf 'S3_PREFIX=%q\n' "$S3_PREFIX"
    printf '# Override the public download URL (blank = derive from endpoint+bucket+prefix).\n'
    printf 'PUBLIC_BASE_URL=%q\n\n' "$PUBLIC_BASE_URL"
    printf '# IDE install dir: "auto" detects from Toolbox, or set an absolute path.\n'
    printf 'PHPSTORM_IDE=%q\n' "$PHPSTORM_IDE"
    printf 'WEBSTORM_IDE=%q\n' "$WEBSTORM_IDE"
    printf 'DATAGRIP_IDE=%q\n' "$DATAGRIP_IDE"
    printf 'GOLAND_IDE=%q\n\n' "$GOLAND_IDE"
    printf 'PROJECT_ROOTS=(\n'
    local r
    for r in "${PROJECT_ROOTS[@]}"; do printf '  %q\n' "$r"; done
    printf ')\n'
    if [[ ${#EXTRA_PROJECTS[@]} -gt 0 ]]; then
      printf '\nEXTRA_PROJECTS=(\n'
      for r in "${EXTRA_PROJECTS[@]}"; do printf '  %q\n' "$r"; done
      printf ')\n'
    fi
  } > "$CONFIG_FILE"
  umask "$oldmask"
  chmod 600 "$CONFIG_FILE" 2>/dev/null || true
}

save_config_if_missing() {
  [[ -f "$CONFIG_FILE" ]] || save_config
}

# ---------------------------------------------------------------------------
# Colours (CLI only, when stdout is a TTY)
# ---------------------------------------------------------------------------

if [[ -t 1 ]]; then
  C_RESET=$'\e[0m'; C_BOLD=$'\e[1m'; C_DIM=$'\e[2m'
  C_GREEN=$'\e[32m'; C_YELLOW=$'\e[33m'; C_RED=$'\e[31m'; C_BLUE=$'\e[34m'
else
  C_RESET= ; C_BOLD= ; C_DIM= ; C_GREEN= ; C_YELLOW= ; C_RED= ; C_BLUE=
fi

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

have_cli() { command -v "$CLI" >/dev/null 2>&1; }
have_mc()  { command -v "$MC"  >/dev/null 2>&1; }

run_low_priority() {
  if command -v ionice >/dev/null 2>&1; then
    nice -n 10 ionice -c2 -n7 "$@"
  else
    nice -n 10 "$@"
  fi
}

sanitize_id() { printf '%s' "$1" | tr -cs 'A-Za-z0-9._-' '-'; }

project_kind() {
  local project="$1"

  if [[ -f "$project/go.mod" || -f "$project/go.work" ]]; then
    echo "goland"; return
  fi
  if [[ -f "$project/artisan" || -f "$project/composer.json" || -f "$project/composer.lock" ]]; then
    echo "phpstorm"; return
  fi
  if [[ -f "$project/package.json" || -f "$project/pnpm-lock.yaml" || -f "$project/yarn.lock" \
        || -f "$project/bun.lock" || -f "$project/bun.lockb" \
        || -f "$project/vite.config.ts" || -f "$project/vite.config.js" ]]; then
    echo "webstorm"; return
  fi
  if [[ -f "$project/.idea/dataSources.xml" ]] || find "$project" -maxdepth 2 -type f -name '*.sql' 2>/dev/null | grep -q .; then
    echo "datagrip"; return
  fi
  echo "webstorm"
}

ide_for_kind() {
  case "$1" in
    phpstorm) printf '%s' "$PHPSTORM_HOME" ;;
    webstorm) printf '%s' "$WEBSTORM_HOME" ;;
    datagrip) printf '%s' "$DATAGRIP_HOME" ;;
    goland)   printf '%s' "$GOLAND_HOME" ;;
    *)        printf '' ;;
  esac
}

# The fingerprint decides whether a project needs re-indexing. It must be stable
# across runs for an unchanged project, so it contains nothing the indexer itself
# rewrites: we drop all .idea/*.xml and *.iml hashing (regenerated every run) and
# exclude .idea / intellij.yaml from `git status`. What remains genuinely affects
# the produced index or its published URL: the IDE version, the committed source,
# uncommitted tracked changes, dependency/build manifests, and the base-url (so
# switching hosting/public URL re-emits a correct intellij.yaml everywhere).
project_fingerprint() {
  local project="$1" ide="$2"

  (
    cd "$project" 2>/dev/null || { printf 'unreadable=%s\n' "$project"; exit 0; }

    printf 'project=%s\n' "$(pwd -P)"
    printf 'ide=%s\n' "$ide"
    printf 'baseurl=%s\n' "${BASE_URL:-}"

    # IDE version: Toolbox path encodes the build, and product-info.json is
    # stable per version -> re-index on IDE upgrade, not on every run.
    [[ -n "$ide" && -f "$ide/product-info.json" ]] && sha256sum "$ide/product-info.json"

    # Committed state + uncommitted TRACKED changes, excluding IDE/session churn
    # so the indexer rewriting .idea / intellij.yaml never invalidates us.
    git rev-parse HEAD 2>/dev/null || true
    git status --porcelain=v1 -uno -- . ':(exclude).idea' ':(exclude)intellij.yaml' 2>/dev/null || true

    # Dependency / build manifests that change what gets indexed.
    local f
    for f in \
      composer.json composer.lock \
      package.json package-lock.json pnpm-lock.yaml pnpm-workspace.yaml yarn.lock bun.lock bun.lockb \
      go.mod go.sum go.work go.work.sum \
      tsconfig.json tsconfig.app.json jsconfig.json \
      vite.config.js vite.config.ts \
      .nvmrc .tool-versions
    do
      [[ -f "$f" ]] && sha256sum "$f"
    done
  ) | sha256sum | awk '{print $1}'
}

# Pull the shared-index YAML block out of the CLI's stdout. The CLI prints the
# `sharedIndex:` (and, for automatic download, `consents:`) section to paste into
# <project>/intellij.yaml. We capture from the first such top-level key through
# the contiguous YAML (indented lines, list items, and sibling top-level keys),
# stopping at the first non-YAML log line or a run of blank lines.
extract_intellij_yaml() {
  local log_file="$1" out_file="$2"
  awk '
    BEGIN { allow["sharedIndex"]=1; allow["sharedIndexes"]=1; allow["consents"]=1; allow["indexLookup"]=1 }
    function topkey(l,   k) { if (l ~ /^[A-Za-z_][A-Za-z0-9_.-]*:/) { k=l; sub(/:.*/,"",k); return k } return "" }
    function yamlish(l) {
      return (l ~ /^[[:space:]]+[^[:space:]]/) || \
             (l ~ /^-[[:space:]]/) || \
             (l ~ /^[A-Za-z_][A-Za-z0-9_.-]*:[[:space:]]*/)
    }
    !started && /^(sharedIndex|sharedIndexes|consents|indexLookup):/ { started=1 }
    started {
      if ($0 ~ /^[[:space:]]*$/) { if (++blank > 1) exit; next }
      k = topkey($0)
      if (k != "" && !(k in allow)) exit   # a column-0 key we do not manage ends the block
      if (!yamlish($0)) exit
      blank = 0
      print
    }
  ' "$log_file" > "$out_file"
  [[ -s "$out_file" ]] && grep -qE '^(sharedIndex|sharedIndexes|consents|indexLookup):' "$out_file"
}

# intellij.yaml is a general IntelliJ project-settings file: `sharedIndex` is just
# one of several top-level sections (compiler, versionControl, repositoryLibrary,
# ...) a team may legitimately commit. So we MERGE rather than overwrite: keep all
# of the existing file's top-level keys except the shared-index ones we manage,
# then append the freshly generated block. This preserves the order-independent
# top-level keys; it does not attempt deep YAML merging (none is needed here).
merge_intellij_yaml() {
  local existing="$1" block="$2" out="$3"

  if [[ -f "$existing" ]]; then
    awk '
      function topkey(l,   k) {
        if (l ~ /^[A-Za-z_][A-Za-z0-9_.-]*:/) { k = l; sub(/:.*/, "", k); return k }
        return ""
      }
      BEGIN { drop["sharedIndex"] = 1; drop["sharedIndexes"] = 1; drop["consents"] = 1; drop["indexLookup"] = 1 }
      {
        k = topkey($0)
        if (k != "")          dropping = (k in drop)
        else if ($0 ~ /^#/)   dropping = 0   # a column-0 comment starts a fresh section
        if (!dropping) print
      }
    ' "$existing" > "$out"
  else
    : > "$out"
  fi

  # Separate preserved content from the appended block with a blank line.
  [[ -s "$out" ]] && printf '\n' >> "$out"
  cat "$block" >> "$out"
}

is_loopback_url() {
  # True when the URL host is localhost/loopback -> intellij.yaml is machine-local.
  case "$1" in
    *://127.0.0.1*|*://localhost*|*://[::1]*|*://0.0.0.0*) return 0 ;;
    *) return 1 ;;
  esac
}

# Per the JetBrains docs, intellij.yaml should be committed so the team inherits
# the shared-index config -- but ONLY when the server URL is reachable by the
# team. A loopback URL (127.0.0.1/localhost) resolves to each developer's OWN
# machine, so committing it would break everyone else. So: for a loopback
# base-url we git-exclude the file; for a real shared/remote (e.g. MinIO) URL we
# leave it tracked and tell you to commit it.
handle_intellij_yaml_vcs() {
  local project="$1"
  [[ -d "$project/.git" ]] || return 0
  mkdir -p "$project/.git/info"
  touch "$project/.git/info/exclude"

  if is_loopback_url "$BASE_URL"; then
    if ! grep -qx '/intellij.yaml' "$project/.git/info/exclude"; then
      printf '\n/intellij.yaml\n' >> "$project/.git/info/exclude"
    fi
    printf '       localhost URL -> kept out of VCS (.git/info/exclude)\n'
  else
    if grep -qx '/intellij.yaml' "$project/.git/info/exclude"; then
      grep -vx '/intellij.yaml' "$project/.git/info/exclude" > "$project/.git/info/exclude.ijsi.tmp" \
        && mv "$project/.git/info/exclude.ijsi.tmp" "$project/.git/info/exclude"
    fi
    printf '       shared URL -> commit %s/intellij.yaml so your team gets the indexes\n' "$project"
  fi
}

is_project_dir() {
  local p="$1"
  [[ -d "$p/.idea" || -f "$p/composer.json" || -f "$p/package.json" \
     || -f "$p/go.mod" || -f "$p/go.work" || -f "$p/artisan" ]]
}

iter_projects() {
  {
    local root project p
    for root in "${PROJECT_ROOTS[@]}"; do
      [[ -d "$root" ]] || continue
      for project in "$root"/*; do
        [[ -d "$project" ]] || continue
        is_project_dir "$project" && printf '%s\n' "$project"
      done
    done
    for p in "${EXTRA_PROJECTS[@]:-}"; do
      [[ -n "$p" && -d "$p" ]] && printf '%s\n' "$p"
    done
  } | awk 'NF && !seen[$0]++'
}

match_only() {
  local project="$1" csv="$2" base n
  base="$(basename "$project")"
  local IFS=','
  for n in $csv; do
    [[ -z "$n" ]] && continue
    [[ "$base" == "$n" || "$project" == *"$n"* ]] && return 0
  done
  return 1
}

count_projects() { iter_projects | wc -l | tr -d ' '; }

# Resolve a CLI argument (a project basename, a path fragment, or an absolute
# path) to a single discovered project directory.
resolve_project_arg() {
  local arg="$1" p
  if [[ -d "$arg" ]] && is_project_dir "$arg"; then
    printf '%s' "$(readlink -f "$arg")"; return 0
  fi
  while IFS= read -r p; do
    [[ "$(basename "$p")" == "$arg" || "$p" == *"$arg"* ]] && { printf '%s' "$p"; return 0; }
  done < <(iter_projects)
  return 1
}

record_result() {
  [[ -n "${IJSI_RESULTS:-}" ]] && printf '%s\t%s\n' "$1" "$2" >> "$IJSI_RESULTS"
  return 0
}

# Returns: 3=indexed  0=up-to-date  4=skipped(no IDE)  1=failed
index_project() {
  local project="$1"
  local kind ide name project_id fingerprint state_file log_file yaml_file

  kind="$(project_kind "$project")"
  ide="$(ide_for_kind "$kind")"
  name="$(basename "$project")"
  project_id="$(sanitize_id "${kind}-${name}")"
  state_file="$STATE_DIR/${project_id}.sha256"

  if [[ -z "$ide" ]]; then
    printf '%sSkip%s   %s  (%s IDE not found)\n' "$C_YELLOW" "$C_RESET" "$project" "$kind"
    record_result skipped "$project"
    return 4
  fi

  if [[ ! -e "$ide/product-info.json" ]]; then
    printf '%sSkip%s   %s  (%s IDE looks incomplete: no product-info.json at %s)\n' \
      "$C_YELLOW" "$C_RESET" "$project" "$kind" "$ide"
    record_result skipped "$project"
    return 4
  fi

  fingerprint="$(project_fingerprint "$project" "$ide")"

  if [[ -z "${IJSI_FORCE:-}" ]] && [[ -f "$state_file" ]] && [[ "$(cat "$state_file")" == "$fingerprint" ]]; then
    printf '%sOK%s     %s  (up to date)\n' "$C_DIM" "$C_RESET" "$project"
    record_result uptodate "$project"
    return 0
  fi

  log_file="$LOG_DIR/${project_id}-$(date +%Y%m%d-%H%M%S).log"
  printf '%sIndex%s  %s  [%s]\n' "$C_BLUE" "$C_RESET" "$project" "$kind"

  if run_low_priority "$CLI" indexes \
      --ij "$ide" \
      --project "$project" \
      --base-url "$BASE_URL" \
      --data-directory "$DATA_DIR" \
      > "$log_file" 2>&1
  then
    printf '%s\n' "$fingerprint" > "$state_file"
    # Mark that fresh indexes exist but are not yet on MinIO. Cleared only after a
    # successful upload, so a failed/interrupted upload is retried on the next run
    # even though the project itself now fingerprints as up to date.
    [[ "$S3_ENABLED" == "yes" ]] && touch "$STATE_DIR/.needs_upload"

    yaml_file="$CONFIG_DIR/${project_id}.intellij.yaml"
    if extract_intellij_yaml "$log_file" "$yaml_file"; then
      if merge_intellij_yaml "$project/intellij.yaml" "$yaml_file" "$project/.intellij.yaml.ijsi.tmp" \
         && mv "$project/.intellij.yaml.ijsi.tmp" "$project/intellij.yaml"; then
        printf '%sDone%s   %s  (merged intellij.yaml -> %s)\n' "$C_GREEN" "$C_RESET" "$project" "$BASE_URL"
        if [[ "$S3_ENABLED" == "yes" ]] && ! grep -qF "$(s3_public_base_url)" "$project/intellij.yaml"; then
          printf '       %sWARNING%s intellij.yaml does not reference %s\n' \
            "$C_YELLOW" "$C_RESET" "$(s3_public_base_url)"
        fi
        handle_intellij_yaml_vcs "$project"
      else
        rm -f "$project/.intellij.yaml.ijsi.tmp"
        printf '%sDone%s   %s  (indexed; could not write intellij.yaml)\n' "$C_YELLOW" "$C_RESET" "$project"
      fi
    else
      printf '%sDone%s   %s  (no intellij.yaml in CLI output; see %s)\n' \
        "$C_GREEN" "$C_RESET" "$project" "$log_file"
    fi
    record_result indexed "$project"
    return 3
  else
    printf '%sFail%s   %s  (see %s)\n' "$C_RED" "$C_RESET" "$project" "$log_file"
    record_result failed "$project"
    return 1
  fi
}

# ---------------------------------------------------------------------------
# MinIO / S3
# ---------------------------------------------------------------------------

mc_alias_label()   { mc_alias_configured && echo "configured" || echo "not set"; }
s3_state_label()   { [[ "$S3_ENABLED" == "yes" ]] && echo "ON (MinIO)" || echo "off (local server)"; }
mc_alias_configured() { have_mc && "$MC" alias ls "$S3_ALIAS" >/dev/null 2>&1; }

# Register/update the mc alias from credentials. Tries the modern verb first,
# falls back to the legacy one. The secret is passed on argv (visible only to
# the same user via /proc) and stored by mc in ~/.mc/config.json, mode 0600.
mc_set_alias() {
  local endpoint="$1" access="$2" secret="$3"
  "$MC" alias set "$S3_ALIAS" "$endpoint" "$access" "$secret" >/dev/null 2>&1 \
    || "$MC" config host add "$S3_ALIAS" "$endpoint" "$access" "$secret" >/dev/null 2>&1
}

# Grant anonymous (public) download on a bucket/prefix. The command was renamed
# from `mc policy` to `mc anonymous`; try newest -> oldest.
mc_set_public() {
  local target="$1" err
  # Keep the legacy fallbacks quiet, but surface the modern verb's error (the most
  # informative one) if every attempt fails.
  err="$("$MC" anonymous set download "$target" 2>&1 >/dev/null)" && return 0
  "$MC" policy set download "$target" >/dev/null 2>&1 && return 0
  "$MC" policy download "$target" >/dev/null 2>&1 && return 0
  [[ -n "$err" ]] && printf '%s\n' "$err" >&2
  return 1
}

# Print one line per readiness problem; return 1 if any, 0 if ready to upload.
s3_preflight() {
  local problems=()
  [[ "$S3_ENABLED" == "yes" ]] || problems+=("upload is disabled (enable it in MinIO settings)")
  have_mc                      || problems+=("mc not found: $MC (install MinIO Client or set MC)")
  mc_alias_configured          || problems+=("mc alias '$S3_ALIAS' not configured (set credentials)")
  [[ -n "$S3_BUCKET" ]]        || problems+=("bucket name not set")
  [[ -n "$(s3_public_base_url)" ]] || problems+=("public base URL/endpoint not set")
  if [[ ${#problems[@]} -gt 0 ]]; then
    printf '%s\n' "${problems[@]}"
    return 1
  fi
  return 0
}

# Upload the generated indexes (contents of the server dir) to the bucket.
# mc mirror is incremental: only changed files are transferred.
s3_publish() {
  local src="$DATA_DIR/server" target
  if [[ ! -d "$src" ]]; then
    echo "Nothing to upload: $src does not exist (run a refresh first)." >&2
    return 1
  fi
  local probs line
  if ! probs="$(s3_preflight)"; then
    echo "MinIO upload not ready:" >&2
    while IFS= read -r line; do echo "  - $line" >&2; done <<< "$probs"
    return 1
  fi
  target="$(s3_target)"
  echo "Uploading shared indexes  $src  ->  $target"
  echo "Public URL: $(s3_public_base_url)"
  if run_low_priority "$MC" mirror --overwrite "$src" "$target"; then
    echo "Upload complete."
    return 0
  fi
  echo "Upload failed (mc mirror). Check 'ijsi s3 test' and the bucket policy." >&2
  return 1
}

# Create the bucket if needed and make it publicly downloadable.
cmd_s3_setup() {
  have_mc || { echo "mc not found: $MC" >&2; return 1; }
  mc_alias_configured || { echo "Set credentials first: ijsi s3 login (or the TUI)." >&2; return 1; }
  [[ -n "$S3_BUCKET" ]] || { echo "Set a bucket name first (ijsi config / TUI)." >&2; return 1; }

  echo "Ensuring bucket exists: $S3_ALIAS/$S3_BUCKET"
  # `mb --ignore-existing` is idempotent: it succeeds if the bucket already exists
  # and fails loudly (with mc's own error) if creation genuinely fails.
  if ! "$MC" mb --ignore-existing "$S3_ALIAS/$S3_BUCKET"; then
    echo "Could not create or verify bucket $S3_ALIAS/$S3_BUCKET (see mc error above)." >&2
    return 1
  fi

  local target; target="$(s3_target)"
  if [[ -z "$S3_PREFIX" ]]; then
    echo "WARNING: no prefix set - the ENTIRE bucket $S3_ALIAS/$S3_BUCKET will be" >&2
    echo "         publicly downloadable and listable. Use a dedicated bucket, or set" >&2
    echo "         a prefix (ijsi config / TUI) to scope the public grant." >&2
  fi
  echo "Granting anonymous download on: $target"
  if mc_set_public "$target"; then
    echo "Public download enabled. IDEs can now fetch indexes from $(s3_public_base_url)"
  else
    echo "Could not set the anonymous policy automatically; set it on $target manually." >&2
    return 1
  fi
}

# Prompt for credentials on the CLI and store them in mc.
cmd_s3_login() {
  have_mc || { echo "mc not found: $MC (install MinIO Client or set MC)." >&2; return 1; }
  local endpoint access secret
  read -r -p "S3 endpoint URL (e.g. https://minio.example.com:9000): " endpoint
  read -r -p "Access key: " access
  read -r -s -p "Secret key (hidden): " secret; echo
  [[ -n "$endpoint" && -n "$access" && -n "$secret" ]] || { echo "All three fields are required." >&2; return 1; }
  if mc_set_alias "$endpoint" "$access" "$secret"; then
    S3_ENDPOINT="$endpoint"; save_config
    echo "Saved credentials to mc alias '$S3_ALIAS' (~/.mc/config.json)."
  else
    echo "Failed to register the mc alias. Check the endpoint and keys." >&2
    return 1
  fi
}

cmd_s3_test() {
  have_mc || { echo "mc not found: $MC" >&2; return 1; }
  mc_alias_configured || { echo "Alias '$S3_ALIAS' not configured (ijsi s3 login)." >&2; return 1; }
  echo "Listing $S3_ALIAS ..."
  if "$MC" ls "$S3_ALIAS"; then
    echo "Connection OK."
  else
    echo "Could not reach $S3_ALIAS. Check endpoint/keys." >&2
    return 1
  fi
}

s3_status() {
  printf 'Upload enabled:    %s\n' "$S3_ENABLED"
  printf 'mc client:         %s\n' "$(have_mc && command -v "$MC" || echo "not found: $MC")"
  printf 'mc alias:          %s  (%s)\n' "$S3_ALIAS" "$(mc_alias_label)"
  printf 'Endpoint:          %s\n' "${S3_ENDPOINT:-<unset>}"
  printf 'Bucket:            %s\n' "${S3_BUCKET:-<unset>}"
  printf 'Prefix:            %s\n' "${S3_PREFIX:-<none>}"
  printf 'Upload target:     %s\n' "$(s3_target)"
  printf 'Public base URL:   %s\n' "$(s3_public_base_url)"
  printf 'Effective base:    %s\n' "$(effective_base_url)"
  if [[ "$S3_ENABLED" == "yes" ]]; then
    if s3_preflight >/dev/null; then
      printf 'Readiness:         READY\n'
    else
      printf 'Readiness:         NOT READY\n'
      s3_preflight | sed 's/^/  - /'
    fi
  fi
  [[ -f "$STATE_DIR/.needs_upload" ]] && printf 'Pending upload:    YES (previous upload incomplete; next refresh/sync retries)\n'
  return 0
}

cmd_s3() {
  case "${1:-status}" in
    status)        s3_status ;;
    login)         cmd_s3_login ;;
    setup)         cmd_s3_setup ;;
    sync|publish)  s3_publish && rm -f "$STATE_DIR/.needs_upload" ;;
    test)          cmd_s3_test ;;
    enable)        S3_ENABLED="yes"; save_config; BASE_URL="$(effective_base_url)"; echo "Upload enabled.  Base-url: $BASE_URL" ;;
    disable)       S3_ENABLED="no";  save_config; BASE_URL="$(effective_base_url)"; echo "Upload disabled. Base-url: $BASE_URL" ;;
    -h|--help|"")  echo "usage: ijsi s3 [status|login|setup|sync|test|enable|disable]" ;;
    *)             echo "s3: unknown subcommand: $1" >&2
                   echo "usage: ijsi s3 [status|login|setup|sync|test|enable|disable]" >&2; return 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# Locking
# ---------------------------------------------------------------------------

# Runs "$@" while holding a non-blocking refresh lock. Returns 100 if busy.
with_refresh_lock() {
  ensure_dirs
  local lockfd
  exec {lockfd}>"$CACHE_DIR/refresh.lock" || return 1
  if ! flock -n "$lockfd"; then
    exec {lockfd}>&-
    return 100
  fi
  "$@"
  local rc=$?
  flock -u "$lockfd"
  exec {lockfd}>&-
  return $rc
}

# ---------------------------------------------------------------------------
# CLI commands
# ---------------------------------------------------------------------------

do_refresh_cli() {
  local force="$1" only="$2"
  local n_idx=0 n_up=0 n_skip=0 n_fail=0 total=0
  local project
  local IJSI_FORCE="$force"   # visible to index_project via bash dynamic scope

  while IFS= read -r project; do
    [[ -z "$project" ]] && continue
    if [[ -n "$only" ]] && ! match_only "$project" "$only"; then continue; fi
    total=$((total + 1))
    index_project "$project"
    case $? in
      3) n_idx=$((n_idx + 1)) ;;
      0) n_up=$((n_up + 1)) ;;
      4) n_skip=$((n_skip + 1)) ;;
      *) n_fail=$((n_fail + 1)) ;;
    esac
  done < <(iter_projects)

  local upload_note=""
  if [[ "$S3_ENABLED" == "yes" ]] && { [[ $n_idx -gt 0 ]] || [[ -f "$STATE_DIR/.needs_upload" ]]; }; then
    echo
    if s3_publish; then
      upload_note="ok"; rm -f "$STATE_DIR/.needs_upload"
    else
      upload_note="FAILED"; n_fail=$((n_fail + 1))
    fi
  fi

  printf '\n%sSummary%s  indexed=%d  up-to-date=%d  skipped=%d  failed=%d  (of %d)' \
    "$C_BOLD" "$C_RESET" "$n_idx" "$n_up" "$n_skip" "$n_fail" "$total"
  [[ -n "$upload_note" ]] && printf '  upload=%s' "$upload_note"
  printf '\n'
  [[ $n_fail -gt 0 ]] && return 1 || return 0
}

cmd_refresh() {
  local force="" only=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--force)   force="1" ;;
      --only)       shift; only="${1:-}" ;;
      --only=*)     only="${1#*=}" ;;
      -h|--help)    echo "usage: ijsi refresh [--force] [--only name,name,...]"; return 0 ;;
      *)            echo "refresh: unknown argument: $1" >&2; return 1 ;;
    esac
    shift
  done

  if ! have_cli; then
    echo "Missing CLI: $CLI" >&2
    echo "Install ij-shared-indexes-tool-cli and ensure it is on PATH (or set IJSI_CLI)." >&2
    return 1
  fi

  if [[ "$S3_ENABLED" == "yes" ]]; then
    local probs line
    if ! probs="$(s3_preflight)"; then
      echo "MinIO upload is enabled but not ready:" >&2
      while IFS= read -r line; do echo "  - $line" >&2; done <<< "$probs"
      echo "Fix it in the TUI (MinIO settings) or run: ijsi s3 setup" >&2
      return 1
    fi
  fi

  with_refresh_lock do_refresh_cli "$force" "$only"
  local rc=$?
  if [[ $rc -eq 100 ]]; then
    echo "Another ijsi refresh is already running. Skipping." >&2
    return 0
  fi
  return $rc
}

cmd_server() {
  ensure_dirs
  if ! have_cli; then
    echo "Missing CLI: $CLI" >&2
    echo "Set IJSI_CLI to the absolute path of ij-shared-indexes-tool-cli" >&2
    echo "(a bare name will not resolve under the systemd --user PATH)." >&2
    return 1
  fi
  exec "$CLI" server --port "$PORT" --server-directory "$DATA_DIR/server"
}

# Doc "boost": measure project-analysis time with vs. without shared indexes.
cmd_boost() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo "usage: ijsi boost <project-name-or-path>" >&2
    echo "Measures project-analysis time with vs. without shared indexes." >&2
    return 1
  fi
  if ! have_cli; then echo "Missing CLI: $CLI" >&2; return 1; fi

  local project kind ide
  project="$(resolve_project_arg "$target")" || { echo "No matching project for: $target" >&2; return 1; }
  kind="$(project_kind "$project")"
  ide="$(ide_for_kind "$kind")"
  if [[ -z "$ide" || ! -e "$ide/product-info.json" ]]; then
    echo "No usable $kind IDE found for $project (set the IDE path in: ijsi config)." >&2
    return 1
  fi

  ensure_dirs
  echo "Boost: measuring shared-index speedup for $project  [$kind]"
  echo "This analyzes the project with and without shared indexes; it can take a while..."
  run_low_priority "$CLI" boost \
    --ij "$ide" \
    --project "$project" \
    --port "$PORT" \
    --data-directory "$DATA_DIR"
}

# Doc "version": the CLI reports the shared-index version for an IDE (--ij).
cmd_version() {
  echo "ijsi $IJSI_VERSION"
  if ! have_cli; then
    echo "(ij-shared-indexes-tool-cli not found: $CLI)"
    return 0
  fi
  local ide="${PHPSTORM_HOME:-${WEBSTORM_HOME:-${GOLAND_HOME:-${DATAGRIP_HOME:-}}}}"
  if [[ -n "$ide" && -e "$ide/product-info.json" ]]; then
    echo
    echo "ij-shared-indexes-tool-cli version (--ij $ide):"
    "$CLI" version --ij "$ide" 2>&1 | sed 's/^/  /'
  else
    echo "(point ijsi at an installed IDE to query the CLI shared-index version)"
  fi
}

