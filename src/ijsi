#!/usr/bin/env bash
#
# ijsi - JetBrains shared-index manager for a fleet of PHP API forks
# ============================================================================
#
# WHAT THIS DOES
#   You keep a single folder of forked PHP/Laravel API repositories (one fork
#   per project). On demand, ijsi walks that folder and, for each repo:
#
#       1. fetches and fast-forwards the repo's default branch ("main"),
#       2. runs `composer install` so vendor/ matches the committed lock,
#       3. generates a JetBrains shared index with the PhpStorm CLI, and
#       4. uploads the index to a MinIO (S3-compatible) bucket.
#
#   Each repo also gets an intellij.yaml pointing PhpStorm at that bucket, so
#   every developer downloads the prebuilt index instead of analysing the
#   project (and its vendor/ dependencies) from scratch.
#
# WHY THE VENDOR DIRECTORY STOPS BEING RE-ANALYSED
#   PhpStorm treats every vendor/* package as a LIBRARY ROOT, and libraries are
#   indexed even though they are "excluded" content. JetBrains shared indexes
#   are matched to a developer's files by the HASH OF EACH FILE'S CONTENTS, not
#   by path. So a vendor file is only covered by a shared index when its bytes
#   are identical to the bytes that existed when the index was generated.
#
#   By generating the index here AFTER `composer install` (from the committed
#   composer.lock), the published index covers vendor/. A teammate gets that
#   coverage as long as they `composer install` from the SAME composer.lock on
#   a compatible PHP version/platform - the normal case. New packages change
#   composer.lock, which is exactly what re-triggers indexing (see below).
#
# WHEN IT RE-INDEXES
#   Re-indexing is on demand (`ijsi refresh`); there is no timer. A repo is
#   re-indexed only when its fingerprint changes. The fingerprint is a hash of:
#       - the tracked tree of origin/<default-branch> EXCLUDING intellij.yaml,
#       - composer.lock + composer.json (new packages => re-index),
#       - the PhpStorm build, and
#       - the published base-url.
#   intellij.yaml is excluded on purpose so that merging the "intellij.yaml fix"
#   PRs ijsi opens never triggers a re-index loop. `ijsi refresh --force`
#   ignores the fingerprint and re-indexes everything.
#
# THE intellij.yaml PR FLOW
#   intellij.yaml must be committed so the whole team inherits the shared-index
#   config. ijsi never commits to your default branch directly: when the
#   generated intellij.yaml differs from the branch, it pushes a stable branch
#   `ijsi/intellij-yaml` and opens (or updates) a PR titled "intellij.yaml fix"
#   via the `gh` CLI. You review and merge. (Configurable: INTELLIJ_YAML_VCS.)
#
# CREDENTIALS
#   S3 credentials live in mc's own store (`mc alias set` -> ~/.mc/config.json,
#   mode 0600). ijsi never writes the secret key to its own config file.
#
# USAGE
#   Run with no arguments to open the TUI. Run `ijsi help` for the CLI.

set -uo pipefail

IJSI_VERSION="4.0.0"

SELF="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"

# ---------------------------------------------------------------------------
# Configuration (defaults < config file < IJSI_* environment overrides)
# ---------------------------------------------------------------------------

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/ijsi"
CONFIG_FILE="${IJSI_CONFIG:-$CONFIG_HOME/config}"

DEFAULT_REPOS_DIR="$HOME/Main"
DEFAULT_CACHE_DIR="$HOME/.cache/ij-shared-indexes"
DEFAULT_TOOLBOX_APPS="$HOME/.local/share/JetBrains/Toolbox/apps"
DEFAULT_S3_ALIAS="ijsi"

# Set by the config file if present; left empty here so env/defaults can win.
REPOS_DIR="" ; CACHE_DIR="" ; CLI="" ; MC="" ; COMPOSER="" ; TOOLBOX_APPS=""
PHPSTORM_IDE="" ; DEFAULT_BRANCH="" ; INTELLIJ_YAML_VCS=""

# MinIO / S3 upload (no secrets here - those live in mc's alias store).
S3_ALIAS="" ; S3_ENDPOINT="" ; S3_BUCKET="" ; S3_PREFIX="" ; PUBLIC_BASE_URL=""

load_config() {
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
  fi
}

apply_env_and_defaults() {
  REPOS_DIR="${IJSI_REPOS_DIR:-${REPOS_DIR:-$DEFAULT_REPOS_DIR}}"
  CLI="${IJSI_CLI:-${CLI:-ij-shared-indexes-tool-cli}}"
  MC="${IJSI_MC:-${MC:-mc}}"
  COMPOSER="${IJSI_COMPOSER:-${COMPOSER:-composer}}"
  CACHE_DIR="${IJSI_CACHE_DIR:-${CACHE_DIR:-$DEFAULT_CACHE_DIR}}"
  TOOLBOX_APPS="${IJSI_TOOLBOX_APPS:-${TOOLBOX_APPS:-$DEFAULT_TOOLBOX_APPS}}"

  # "auto" (detect from Toolbox/opt) or an absolute install dir.
  PHPSTORM_IDE="${IJSI_PHPSTORM_IDE:-${PHPSTORM_IDE:-auto}}"
  # Branch to track per repo. Empty = auto-detect origin/HEAD (then main, master).
  DEFAULT_BRANCH="${IJSI_DEFAULT_BRANCH:-${DEFAULT_BRANCH:-}}"
  # How to get intellij.yaml into VCS: pr | leave | off
  INTELLIJ_YAML_VCS="${IJSI_INTELLIJ_YAML_VCS:-${INTELLIJ_YAML_VCS:-pr}}"

  S3_ALIAS="${IJSI_S3_ALIAS:-${S3_ALIAS:-$DEFAULT_S3_ALIAS}}"
  S3_ENDPOINT="${IJSI_S3_ENDPOINT:-${S3_ENDPOINT:-}}"
  S3_BUCKET="${IJSI_S3_BUCKET:-${S3_BUCKET:-}}"
  S3_PREFIX="${IJSI_S3_PREFIX:-${S3_PREFIX:-}}"
  PUBLIC_BASE_URL="${IJSI_PUBLIC_BASE_URL:-${PUBLIC_BASE_URL:-}}"

  DATA_DIR="$CACHE_DIR/tool-data"
  STATE_DIR="$CACHE_DIR/state"
  LOG_DIR="$CACHE_DIR/logs"
  CONFIG_DIR="$CACHE_DIR/configs"
  PRWT_DIR="$CACHE_DIR/pr-worktrees"

  # Resolved PhpStorm install dir actually passed to the CLI.
  PHPSTORM_HOME="$(resolve_phpstorm "$PHPSTORM_IDE")"

  # The base-url baked into intellij.yaml and passed to the CLI when generating:
  # always the public MinIO bucket URL (there is no local-server mode any more).
  BASE_URL="$(s3_public_base_url)"
}

# Find a PhpStorm install. Explicit absolute path wins; "auto" searches Toolbox.
resolve_phpstorm() {
  local configured="$1"
  if [[ -n "$configured" && "$configured" != "auto" ]]; then
    printf '%s' "$configured"; return 0
  fi
  local r found=""
  for r in "$TOOLBOX_APPS" "$HOME/.local/share/JetBrains" "/opt"; do
    [[ -d "$r" ]] || continue
    found="$(find "$r" -maxdepth 8 -type f -name phpstorm.sh 2>/dev/null | sort -V | tail -n 1)"
    if [[ -n "$found" ]]; then
      printf '%s' "$(dirname "$(dirname "$found")")"; return 0
    fi
  done
  printf ''
}

# ---------------------------------------------------------------------------
# Base-url / S3 target helpers
# ---------------------------------------------------------------------------

# Public download URL the IDE uses. Explicit PUBLIC_BASE_URL wins (e.g. a CDN or
# reverse proxy); otherwise derive it from endpoint + bucket + prefix.
s3_public_base_url() {
  if [[ -n "$PUBLIC_BASE_URL" ]]; then
    printf '%s' "${PUBLIC_BASE_URL%/}"; return
  fi
  # Without an endpoint there is no valid base-url; never emit a host-less "/bucket".
  [[ -n "$S3_ENDPOINT" ]] || return 0
  local u="${S3_ENDPOINT%/}"
  [[ -n "$S3_BUCKET" ]] && u="$u/$S3_BUCKET"
  [[ -n "$S3_PREFIX" ]] && u="$u/${S3_PREFIX#/}"
  printf '%s' "$u"
}

# Where index files are uploaded with mc:  <alias>/<bucket>[/<prefix>]
s3_target() {
  local t="$S3_ALIAS/$S3_BUCKET"
  [[ -n "$S3_PREFIX" ]] && t="$t/${S3_PREFIX#/}"
  printf '%s' "$t"
}

ensure_dirs() {
  mkdir -p "$CONFIG_HOME" "$DATA_DIR" "$STATE_DIR" "$LOG_DIR" "$CONFIG_DIR" "$PRWT_DIR"
}

save_config() {
  mkdir -p "$CONFIG_HOME"
  # Tighten an existing config's perms BEFORE truncating it, so a previously
  # loose-perms file is never briefly readable while we rewrite it.
  [[ -f "$CONFIG_FILE" ]] && chmod 600 "$CONFIG_FILE" 2>/dev/null
  # Write under a tight umask so a new file is never momentarily world-readable.
  local oldmask; oldmask="$(umask)"
  umask 077
  {
    printf '# ijsi configuration  -  sourced as bash. IJSI_* env vars override these.\n'
    printf '# Edit by hand, or via:  ijsi  ->  Configure / MinIO settings.\n'
    printf '# NOTE: S3 credentials are NOT stored here; they live in mc (~/.mc/config.json).\n\n'
    printf '# Folder containing your forked API repositories (one repo per subfolder).\n'
    printf 'REPOS_DIR=%q\n\n' "$REPOS_DIR"
    printf 'CACHE_DIR=%q\n' "$CACHE_DIR"
    printf 'CLI=%q\n' "$CLI"
    printf 'MC=%q\n' "$MC"
    printf 'COMPOSER=%q\n' "$COMPOSER"
    printf 'TOOLBOX_APPS=%q\n\n' "$TOOLBOX_APPS"
    printf '# PhpStorm install dir: "auto" detects from Toolbox, or set an absolute path.\n'
    printf 'PHPSTORM_IDE=%q\n' "$PHPSTORM_IDE"
    printf '# Branch to track per repo. Empty = auto-detect (origin/HEAD, then main/master).\n'
    printf 'DEFAULT_BRANCH=%q\n' "$DEFAULT_BRANCH"
    printf '# How intellij.yaml reaches VCS:  pr (open a PR) | leave (write only) | off.\n'
    printf 'INTELLIJ_YAML_VCS=%q\n\n' "$INTELLIJ_YAML_VCS"
    printf '# MinIO / S3 upload (mc alias holds the access/secret keys).\n'
    printf 'S3_ALIAS=%q\n' "$S3_ALIAS"
    printf 'S3_ENDPOINT=%q\n' "$S3_ENDPOINT"
    printf 'S3_BUCKET=%q\n' "$S3_BUCKET"
    printf 'S3_PREFIX=%q\n' "$S3_PREFIX"
    printf '# Override the public download URL (blank = derive from endpoint+bucket+prefix).\n'
    printf 'PUBLIC_BASE_URL=%q\n' "$PUBLIC_BASE_URL"
  } > "$CONFIG_FILE"
  umask "$oldmask"
  chmod 600 "$CONFIG_FILE" 2>/dev/null || true
}

save_config_if_missing() { [[ -f "$CONFIG_FILE" ]] || save_config; }

# ---------------------------------------------------------------------------
# Colours (CLI only, when stdout is a TTY)
# ---------------------------------------------------------------------------

if [[ -t 1 ]]; then
  C_RESET=$'\e[0m'; C_BOLD=$'\e[1m'; C_DIM=$'\e[2m'
  C_GREEN=$'\e[32m'; C_YELLOW=$'\e[33m'; C_RED=$'\e[31m'; C_BLUE=$'\e[34m'
else
  C_RESET= ; C_BOLD= ; C_DIM= ; C_GREEN= ; C_YELLOW= ; C_RED= ; C_BLUE=
fi

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

have_cli()      { command -v "$CLI" >/dev/null 2>&1; }
have_mc()       { command -v "$MC"  >/dev/null 2>&1; }
have_composer() { command -v "$COMPOSER" >/dev/null 2>&1; }
have_gh()       { command -v gh >/dev/null 2>&1; }

run_low_priority() {
  if command -v ionice >/dev/null 2>&1; then
    nice -n 10 ionice -c2 -n7 "$@"
  else
    nice -n 10 "$@"
  fi
}

sanitize_id() { printf '%s' "$1" | tr -cs 'A-Za-z0-9._-' '-'; }

# Collision-resistant per-repo id: sanitized basename + a short hash of the
# absolute path, so two repos whose names differ only in punctuation (e.g.
# "api.billing" vs "api-billing") never share a state file or PR worktree.
repo_id_for() {
  local repo="$1" abs
  abs="$(cd "$repo" 2>/dev/null && pwd -P || printf '%s' "$repo")"
  printf '%s-%s' "$(sanitize_id "$(basename "$abs")")" "$(printf '%s' "$abs" | sha256sum | cut -c1-8)"
}

# A repo is a candidate when it is a git working tree containing a PHP project.
is_repo() {
  local p="$1"
  [[ -d "$p/.git" ]] && { [[ -f "$p/composer.json" || -f "$p/artisan" ]]; }
}

# Every candidate repo directly under REPOS_DIR, de-duplicated, sorted.
iter_repos() {
  [[ -d "$REPOS_DIR" ]] || return 0
  local d
  for d in "$REPOS_DIR"/*; do
    [[ -d "$d" ]] || continue
    is_repo "$d" && printf '%s\n' "$d"
  done | sort -u
}

count_repos() { iter_repos | wc -l | tr -d ' '; }

# Resolve a CLI argument (basename, path fragment, or absolute path) to one repo.
resolve_repo_arg() {
  local arg="$1" p
  if [[ -d "$arg" ]] && is_repo "$arg"; then
    printf '%s' "$(readlink -f "$arg")"; return 0
  fi
  local match=""
  while IFS= read -r p; do
    [[ "$(basename "$p")" == "$arg" ]] && { printf '%s' "$p"; return 0; }   # exact wins
    [[ -z "$match" && "$(basename "$p")" == *"$arg"* ]] && match="$p"        # basename fragment
  done < <(iter_repos)
  [[ -n "$match" ]] && { printf '%s' "$match"; return 0; }
  return 1
}

# True if the repo basename matches any name in a comma-separated --only list.
match_only() {
  local repo="$1" csv="$2" base n
  base="$(basename "$repo")"
  local IFS=','
  for n in $csv; do
    [[ -z "$n" ]] && continue
    # Match on the repo basename only - never the full path, so a fragment that
    # happens to appear in REPOS_DIR (e.g. "api") cannot over-select every repo.
    [[ "$base" == "$n" || "$base" == *"$n"* ]] && return 0
  done
  return 1
}

record_result() {
  [[ -n "${IJSI_RESULTS:-}" ]] && printf '%s\t%s\n' "$1" "$2" >> "$IJSI_RESULTS"
  return 0
}

# ---------------------------------------------------------------------------
# Git: default branch + fast-forward update
# ---------------------------------------------------------------------------

# The branch we treat as "main" for a repo. DEFAULT_BRANCH overrides; otherwise
# origin/HEAD, then a present origin/main or origin/master, else "main".
repo_default_branch() {
  local repo="$1" b
  if [[ -n "$DEFAULT_BRANCH" ]]; then printf '%s' "$DEFAULT_BRANCH"; return; fi
  b="$(git -C "$repo" symbolic-ref --short -q refs/remotes/origin/HEAD 2>/dev/null)"
  if [[ -z "$b" ]]; then
    git -C "$repo" remote set-head origin -a >/dev/null 2>&1
    b="$(git -C "$repo" symbolic-ref --short -q refs/remotes/origin/HEAD 2>/dev/null)"
  fi
  if [[ -n "$b" ]]; then printf '%s' "${b#origin/}"; return; fi
  if git -C "$repo" show-ref --verify --quiet refs/remotes/origin/main;   then printf 'main';   return; fi
  if git -C "$repo" show-ref --verify --quiet refs/remotes/origin/master; then printf 'master'; return; fi
  printf 'main'
}

# Check out <branch> and fast-forward it to origin/<branch>. Our own regenerated
# intellij.yaml is discarded first so it never blocks the fast-forward. Returns
# non-zero (without mutating further) if the working tree has other local
# changes, or the branch has diverged from origin - the caller then skips it.
update_repo() {
  local repo="$1" branch="$2"
  # Only operate when the repo is ALREADY on its default branch - never switch a
  # developer's working branch out from under them. Caller reports the skip.
  local current
  current="$(git -C "$repo" symbolic-ref --short -q HEAD 2>/dev/null || true)"
  [[ "$current" == "$branch" ]] || return 1
  # Now safe: discard our own regenerated intellij.yaml so it can't block the ff.
  git -C "$repo" checkout -- intellij.yaml 2>/dev/null || true
  git -C "$repo" merge --ff-only "origin/$branch" >/dev/null 2>&1 || return 1
  return 0
}

# ---------------------------------------------------------------------------
# Fingerprint - decides whether a repo needs re-indexing
# ---------------------------------------------------------------------------

# Stable across runs for an unchanged main branch. It deliberately excludes
# intellij.yaml (so merging ijsi's own PRs never re-triggers indexing) and is
# computed from the COMMITTED tree of origin/<branch> (not the working tree), so
# the indexer rewriting files locally cannot invalidate us. composer.lock /
# composer.json are folded in explicitly so "new packages" always re-indexes.
repo_fingerprint() {
  local repo="$1" branch="$2" ide="$3" tree
  # Committed tree of the tracked branch, minus the IDE-managed intellij.yaml
  # (so merging our own intellij.yaml PR never changes the fingerprint). ls-tree
  # lines are "<mode> <type> <objectid>\t<path>"; the awk filter drops the row
  # whose PATH is intellij.yaml. pipefail makes this fail if ls-tree errors, so a
  # transient git failure aborts rather than silently dropping the source state.
  tree="$(git -C "$repo" ls-tree -r "origin/$branch" 2>/dev/null | awk -F'\t' '$2 != "intellij.yaml"')" || return 1
  {
    printf 'ide=%s\n' "$ide"
    printf 'baseurl=%s\n' "${BASE_URL:-}"
    # Hash file contents via stdin so the (machine-specific) path is NOT embedded
    # in the digest - moving REPOS_DIR then does not force a full re-index.
    [[ -n "$ide" && -f "$ide/product-info.json" ]] && sha256sum < "$ide/product-info.json"
    printf '%s\n' "$tree"
    # Dependency manifests (also covers a repo that, unusually, gitignores them).
    local f
    for f in composer.lock composer.json; do
      [[ -f "$repo/$f" ]] && sha256sum < "$repo/$f"
    done
  } | sha256sum | awk '{print $1}'
}

# ---------------------------------------------------------------------------
# intellij.yaml extraction / merge / VCS
# ---------------------------------------------------------------------------

# Pull the shared-index YAML block out of the CLI's stdout. The CLI prints the
# `sharedIndex:` (and, for automatic download, `consents:`) section to paste into
# <project>/intellij.yaml. We capture from the first such top-level key through
# the contiguous YAML, stopping at the first non-YAML log line or a run of blanks.
extract_intellij_yaml() {
  local log_file="$1" out_file="$2"
  awk '
    BEGIN { allow["sharedIndex"]=1; allow["sharedIndexes"]=1; allow["consents"]=1; allow["indexLookup"]=1 }
    function topkey(l,   k) { if (l ~ /^[A-Za-z_][A-Za-z0-9_.-]*:/) { k=l; sub(/:.*/,"",k); return k } return "" }
    function yamlish(l) {
      return (l ~ /^[[:space:]]+[^[:space:]]/) || \
             (l ~ /^-[[:space:]]/) || \
             (l ~ /^[A-Za-z_][A-Za-z0-9_.-]*:[[:space:]]*/)
    }
    !started && /^(sharedIndex|sharedIndexes|consents|indexLookup):/ { started=1 }
    started {
      if ($0 ~ /^[[:space:]]*$/) { if (++blank > 1) exit; next }
      k = topkey($0)
      if (k != "" && !(k in allow)) exit   # a column-0 key we do not manage ends the block
      if (!yamlish($0)) exit
      blank = 0
      print
    }
  ' "$log_file" > "$out_file"
  [[ -s "$out_file" ]] && grep -qE '^(sharedIndex|sharedIndexes|consents|indexLookup):' "$out_file"
}

# intellij.yaml is a general IntelliJ project-settings file: `sharedIndex` is just
# one of several top-level sections a team may legitimately commit. So we MERGE
# rather than overwrite: keep all of the existing file's top-level keys except the
# shared-index ones we manage, then append the freshly generated block.
merge_intellij_yaml() {
  local existing="$1" block="$2" out="$3"
  if [[ -f "$existing" ]]; then
    awk '
      function topkey(l,   k) {
        if (l ~ /^[A-Za-z_][A-Za-z0-9_.-]*:/) { k = l; sub(/:.*/, "", k); return k }
        return ""
      }
      BEGIN { drop["sharedIndex"] = 1; drop["sharedIndexes"] = 1; drop["consents"] = 1; drop["indexLookup"] = 1 }
      {
        k = topkey($0)
        if (k != "")          dropping = (k in drop)
        else if ($0 ~ /^#/)   dropping = 0   # a column-0 comment starts a fresh section
        if (dropping) next
        # Buffer blank lines and only emit them once a real line follows. This drops
        # trailing blanks (e.g. the separator that preceded a removed block), so the
        # merge is a FIXED POINT: merge(merge(x)) == merge(x). Without this, each run
        # would accrue a blank line and trigger a needless intellij.yaml PR push.
        if ($0 ~ /^[[:space:]]*$/) { pending++; next }
        for (; pending > 0; pending--) print ""
        print
      }
    ' "$existing" > "$out"
  else
    : > "$out"
  fi
  # Exactly one blank line separates preserved content from the appended block.
  [[ -s "$out" ]] && printf '\n' >> "$out"
  cat "$block" >> "$out"
}

# Make sure a previous ijsi version's git-exclude of intellij.yaml is undone, so
# the file is tracked (committable) again. Only touches the local exclude file.
unignore_intellij_yaml() {
  local repo="$1" ex="$repo/.git/info/exclude"
  [[ -f "$ex" ]] || return 0
  if grep -qx '/intellij.yaml' "$ex" 2>/dev/null; then
    # grep -v exits 1 when it removes the only line (no output); do not gate the
    # mv on that, or the exclude entry would survive. An empty exclude file is ok.
    { grep -vx '/intellij.yaml' "$ex" > "$ex.ijsi.tmp" 2>/dev/null || true; }
    mv "$ex.ijsi.tmp" "$ex" 2>/dev/null || rm -f "$ex.ijsi.tmp"
  fi
}

intellij_pr_body() {
  cat <<'EOF'
Adds/updates `intellij.yaml` so PhpStorm downloads the team's prebuilt JetBrains
shared index (project sources + vendor dependencies) from the MinIO bucket
instead of indexing the project from scratch.

Generated automatically by `ijsi`. This PR changes only `intellij.yaml`. Safe to
merge after a glance. The `ijsi/intellij-yaml` branch is managed by ijsi and is
force-pushed on each update - please don't push your own commits to it.
EOF
}

# Open or update a PR that lands the regenerated intellij.yaml on the default
# branch. Idempotent and non-spammy: does nothing when the branch already has the
# same content, and reuses an existing open PR. Uses a throwaway git worktree so
# the repo's own checkout / indexed state is never disturbed.
open_intellij_pr() {
  local repo="$1" branch="$2" name="$3"
  local gen="$repo/intellij.yaml"
  [[ -f "$gen" ]] || return 0

  if ! have_gh; then
    printf '       %sNote%s gh CLI not found - skipping intellij.yaml PR (install gh, or set INTELLIJ_YAML_VCS=leave)\n' "$C_YELLOW" "$C_RESET"
    return 0
  fi
  if ! ( cd "$repo" && gh repo view >/dev/null 2>&1 ); then
    printf '       %sNote%s no GitHub remote / gh not authed - skipping intellij.yaml PR\n' "$C_YELLOW" "$C_RESET"
    return 0
  fi

  local new cur
  new="$(cat "$gen")"
  cur="$(git -C "$repo" show "origin/$branch:intellij.yaml" 2>/dev/null || true)"
  if [[ "$new" == "$cur" ]]; then
    printf '       intellij.yaml already current on %s - no PR needed\n' "$branch"
    return 0
  fi

  local pr_branch="ijsi/intellij-yaml" prcur
  git -C "$repo" fetch origin "$pr_branch" >/dev/null 2>&1 || true
  prcur="$(git -C "$repo" show "origin/$pr_branch:intellij.yaml" 2>/dev/null || true)"

  if [[ "$new" != "$prcur" ]]; then
    # Build the PR commit in a DETACHED throwaway worktree at origin/<branch> and
    # push it straight to the PR ref. Using a detached worktree (not a named local
    # branch) means we never collide with a branch that is checked out elsewhere.
    local wt="$PRWT_DIR/$(repo_id_for "$repo")"
    rm -rf "$wt"
    git -C "$repo" worktree prune >/dev/null 2>&1
    if ! git -C "$repo" worktree add -f --detach "$wt" "origin/$branch" >/dev/null 2>&1; then
      git -C "$repo" worktree prune >/dev/null 2>&1
      printf '       %sNote%s could not prepare PR worktree - skipping intellij.yaml PR\n' "$C_YELLOW" "$C_RESET"
      return 0
    fi
    cp "$gen" "$wt/intellij.yaml"
    git -C "$wt" add -f intellij.yaml >/dev/null 2>&1
    if git -C "$wt" diff --cached --quiet; then
      git -C "$repo" worktree remove --force "$wt" >/dev/null 2>&1
      printf '       intellij.yaml unchanged vs %s - no PR needed\n' "$branch"
      return 0
    fi
    # Use the repo's git identity when set; otherwise fall back to a bot identity
    # so the commit still succeeds on a host with no configured user.
    local cargs=(-c commit.gpgsign=false)
    git -C "$wt" config user.email >/dev/null 2>&1 || cargs+=(-c user.name=ijsi -c user.email=ijsi@localhost)
    if ! git -C "$wt" "${cargs[@]}" commit -q -m "intellij.yaml fix" >/dev/null 2>&1; then
      git -C "$repo" worktree remove --force "$wt" >/dev/null 2>&1
      printf '       %sNote%s could not create the intellij.yaml commit - skipping PR\n' "$C_YELLOW" "$C_RESET"
      return 0
    fi
    if ! git -C "$wt" push -f origin "HEAD:refs/heads/$pr_branch" >/dev/null 2>&1; then
      git -C "$repo" worktree remove --force "$wt" >/dev/null 2>&1
      printf '       %sNote%s could not push %s to origin (no push access?) - skipping PR\n' "$C_YELLOW" "$C_RESET" "$pr_branch"
      return 0
    fi
    git -C "$repo" worktree remove --force "$wt" >/dev/null 2>&1
  fi

  # Only an OPEN PR counts as "already open" - a merged/closed PR for this head
  # must NOT suppress opening a fresh one for the just-pushed change.
  local pr_state
  pr_state="$( cd "$repo" && gh pr view "$pr_branch" --json state -q .state 2>/dev/null )"
  if [[ "$pr_state" == "OPEN" ]]; then
    printf '       %sPR%s     intellij.yaml fix already open (branch %s updated)\n' "$C_GREEN" "$C_RESET" "$pr_branch"
  elif ( cd "$repo" && gh pr create --base "$branch" --head "$pr_branch" \
            --title "intellij.yaml fix" --body "$(intellij_pr_body)" >/dev/null 2>&1 ); then
    printf '       %sPR%s     opened "intellij.yaml fix"  (%s -> %s)\n' "$C_GREEN" "$C_RESET" "$pr_branch" "$branch"
  else
    printf '       %sNote%s pushed %s but could not open PR (open it manually)\n' "$C_YELLOW" "$C_RESET" "$pr_branch"
  fi
}

# Land the regenerated intellij.yaml according to INTELLIJ_YAML_VCS.
handle_intellij_yaml() {
  local repo="$1" branch="$2" name="$3"
  case "$INTELLIJ_YAML_VCS" in
    off)   : ;;                                   # leave the file, touch nothing
    leave) unignore_intellij_yaml "$repo" ;;      # tracked + modified; you commit
    pr|*)  unignore_intellij_yaml "$repo"; open_intellij_pr "$repo" "$branch" "$name" ;;
  esac
}

# ---------------------------------------------------------------------------
# Index one repo
# Returns: 3=indexed  0=up-to-date  4=skipped  1=failed
# ---------------------------------------------------------------------------

index_repo() {
  local repo="$1"
  local name ide repo_id fingerprint state_file log_file yaml_file branch rc

  name="$(basename "$repo")"
  repo_id="$(repo_id_for "$repo")"
  state_file="$STATE_DIR/${repo_id}.sha256"
  ide="$PHPSTORM_HOME"

  if [[ -z "$ide" || ! -e "$ide/product-info.json" ]]; then
    printf '%sSkip%s   %s  (PhpStorm not found; set PHPSTORM_IDE in: ijsi config)\n' "$C_YELLOW" "$C_RESET" "$repo"
    record_result skipped "$repo"; return 4
  fi

  # Update to latest main before anything else.
  if ! git -C "$repo" fetch --prune origin >/dev/null 2>&1; then
    printf '%sSkip%s   %s  (git fetch failed - no network / remote?)\n' "$C_YELLOW" "$C_RESET" "$repo"
    record_result skipped "$repo"; return 4
  fi
  branch="$(repo_default_branch "$repo")"
  if ! update_repo "$repo" "$branch"; then
    printf '%sSkip%s   %s  (not on %s, or dirty/diverged - cannot fast-forward)\n' "$C_YELLOW" "$C_RESET" "$repo" "$branch"
    record_result skipped "$repo"; return 4
  fi

  fingerprint="$(repo_fingerprint "$repo" "$branch" "$ide")"
  if [[ -z "$fingerprint" ]]; then
    printf '%sSkip%s   %s  (could not compute fingerprint - git error?)\n' "$C_YELLOW" "$C_RESET" "$repo"
    record_result skipped "$repo"; return 4
  fi
  if [[ -z "${IJSI_FORCE:-}" ]] && [[ -f "$state_file" ]] && [[ "$(cat "$state_file")" == "$fingerprint" ]]; then
    printf '%sOK%s     %s  (up to date on %s)\n' "$C_DIM" "$C_RESET" "$repo" "$branch"
    record_result uptodate "$repo"; return 0
  fi

  # Unique per run: a bare seconds timestamp can collide when the same repo is
  # re-indexed twice in one second, which would make the `>>` below append to the
  # previous run's log and extract_intellij_yaml then pull the STALE first block.
  log_file="$(mktemp "$LOG_DIR/${repo_id}-$(date +%Y%m%d-%H%M%S)-XXXXXX.log")"
  printf '%sIndex%s  %s  [%s]  composer install + shared index\n' "$C_BLUE" "$C_RESET" "$repo" "$branch"

  # 1) composer install so vendor/ matches the committed lock at index time.
  {
    printf '===== composer install =====\n'
    ( cd "$repo" && run_low_priority "$COMPOSER" install --no-interaction --no-progress --prefer-dist )
  } >> "$log_file" 2>&1
  rc=$?
  if [[ $rc -ne 0 ]]; then
    printf '%sFail%s   %s  (composer install failed; see %s)\n' "$C_RED" "$C_RESET" "$repo" "$log_file"
    record_result failed "$repo"; return 1
  fi

  # 2) generate the shared index.
  {
    printf '\n===== shared-index generation =====\n'
    run_low_priority "$CLI" indexes \
      --ij "$ide" \
      --project "$repo" \
      --base-url "$BASE_URL" \
      --data-directory "$DATA_DIR"
  } >> "$log_file" 2>&1
  rc=$?
  if [[ $rc -ne 0 ]]; then
    printf '%sFail%s   %s  (indexing failed; see %s)\n' "$C_RED" "$C_RESET" "$repo" "$log_file"
    record_result failed "$repo"; return 1
  fi

  printf '%s\n' "$fingerprint" > "$state_file"
  # Fresh indexes exist but are not yet on MinIO. Cleared only after a successful
  # upload, so an interrupted upload is retried on the next refresh.
  touch "$STATE_DIR/.needs_upload"

  # 3) intellij.yaml: extract -> merge -> land via PR (per INTELLIJ_YAML_VCS).
  yaml_file="$CONFIG_DIR/${repo_id}.intellij.yaml"
  if extract_intellij_yaml "$log_file" "$yaml_file"; then
    if merge_intellij_yaml "$repo/intellij.yaml" "$yaml_file" "$repo/.intellij.yaml.ijsi.tmp" \
       && mv "$repo/.intellij.yaml.ijsi.tmp" "$repo/intellij.yaml"; then
      printf '%sDone%s   %s  (indexed; intellij.yaml -> %s)\n' "$C_GREEN" "$C_RESET" "$repo" "$BASE_URL"
      local burl; burl="$(s3_public_base_url)"
      if [[ -n "$burl" ]] && ! grep -qF "$burl" "$repo/intellij.yaml"; then
        printf '       %sWARNING%s intellij.yaml does not reference %s\n' "$C_YELLOW" "$C_RESET" "$burl"
      fi
      handle_intellij_yaml "$repo" "$branch" "$name"
    else
      rm -f "$repo/.intellij.yaml.ijsi.tmp"
      printf '%sDone%s   %s  (indexed; could not write intellij.yaml)\n' "$C_YELLOW" "$C_RESET" "$repo"
    fi
  else
    printf '%sDone%s   %s  (indexed; no intellij.yaml in CLI output; see %s)\n' "$C_GREEN" "$C_RESET" "$repo" "$log_file"
  fi
  record_result indexed "$repo"; return 3
}

# ---------------------------------------------------------------------------
# MinIO / S3
# ---------------------------------------------------------------------------

mc_alias_label()      { mc_alias_configured && echo "configured" || echo "not set"; }
mc_alias_configured() { have_mc && "$MC" alias ls "$S3_ALIAS" >/dev/null 2>&1; }

# Register/update the mc alias from credentials. Tries the modern verb first,
# falls back to the legacy one. The secret is stored by mc in ~/.mc/config.json.
mc_set_alias() {
  local endpoint="$1" access="$2" secret="$3"
  "$MC" alias set "$S3_ALIAS" "$endpoint" "$access" "$secret" >/dev/null 2>&1 \
    || "$MC" config host add "$S3_ALIAS" "$endpoint" "$access" "$secret" >/dev/null 2>&1
}

# Grant anonymous (public) download on a bucket/prefix (the command was renamed
# from `mc policy` to `mc anonymous`; try newest -> oldest).
mc_set_public() {
  local target="$1" err
  err="$("$MC" anonymous set download "$target" 2>&1 >/dev/null)" && return 0
  "$MC" policy set download "$target" >/dev/null 2>&1 && return 0
  "$MC" policy download "$target" >/dev/null 2>&1 && return 0
  [[ -n "$err" ]] && printf '%s\n' "$err" >&2
  return 1
}

# Print one line per readiness problem; return 1 if any, 0 if ready to upload.
s3_preflight() {
  local problems=() burl
  burl="$(s3_public_base_url)"
  have_mc                          || problems+=("mc not found: $MC (install MinIO Client or set MC)")
  mc_alias_configured              || problems+=("mc alias '$S3_ALIAS' not configured (run: ijsi s3 login)")
  [[ -n "$S3_BUCKET" ]]            || problems+=("bucket name not set (ijsi config / TUI)")
  [[ "$burl" =~ ^[a-zA-Z][a-zA-Z0-9+.-]*:// ]] || problems+=("public base URL has no scheme; set S3_ENDPOINT (https://...) or PUBLIC_BASE_URL")
  if [[ ${#problems[@]} -gt 0 ]]; then
    printf '%s\n' "${problems[@]}"; return 1
  fi
  return 0
}

# Upload generated indexes (contents of the server dir) to the bucket.
# mc mirror is incremental: only changed files are transferred.
s3_publish() {
  local src="$DATA_DIR/server" target
  if [[ ! -d "$src" ]]; then
    echo "Nothing to upload: $src does not exist (run a refresh first)." >&2
    return 1
  fi
  local probs line
  if ! probs="$(s3_preflight)"; then
    echo "MinIO upload not ready:" >&2
    while IFS= read -r line; do echo "  - $line" >&2; done <<< "$probs"
    return 1
  fi
  target="$(s3_target)"
  echo "Uploading shared indexes  $src  ->  $target"
  echo "Public URL: $(s3_public_base_url)"
  if run_low_priority "$MC" mirror --overwrite "$src" "$target"; then
    echo "Upload complete."; return 0
  fi
  echo "Upload failed (mc mirror). Check 'ijsi s3 test' and the bucket policy." >&2
  return 1
}

# Create the bucket if needed and make it publicly downloadable.
cmd_s3_setup() {
  have_mc || { echo "mc not found: $MC" >&2; return 1; }
  mc_alias_configured || { echo "Set credentials first: ijsi s3 login (or the TUI)." >&2; return 1; }
  [[ -n "$S3_BUCKET" ]] || { echo "Set a bucket name first (ijsi config / TUI)." >&2; return 1; }

  echo "Ensuring bucket exists: $S3_ALIAS/$S3_BUCKET"
  if ! "$MC" mb --ignore-existing "$S3_ALIAS/$S3_BUCKET"; then
    echo "Could not create or verify bucket $S3_ALIAS/$S3_BUCKET (see mc error above)." >&2
    return 1
  fi

  local target; target="$(s3_target)"
  if [[ -z "$S3_PREFIX" ]]; then
    echo "WARNING: no prefix set - the ENTIRE bucket $S3_ALIAS/$S3_BUCKET will be" >&2
    echo "         publicly downloadable and listable. Use a dedicated bucket, or set" >&2
    echo "         a prefix (ijsi config / TUI) to scope the public grant." >&2
  fi
  echo "Granting anonymous download on: $target"
  if mc_set_public "$target"; then
    echo "Public download enabled. IDEs can now fetch indexes from $(s3_public_base_url)"
  else
    echo "Could not set the anonymous policy automatically; set it on $target manually." >&2
    return 1
  fi
}

# Prompt for credentials on the CLI and store them in mc.
cmd_s3_login() {
  have_mc || { echo "mc not found: $MC (install MinIO Client or set MC)." >&2; return 1; }
  local endpoint access secret
  read -r -p "S3 endpoint URL (e.g. https://minio.example.com:9000): " endpoint
  read -r -p "Access key: " access
  read -r -s -p "Secret key (hidden): " secret; echo
  [[ -n "$endpoint" && -n "$access" && -n "$secret" ]] || { echo "All three fields are required." >&2; return 1; }
  if mc_set_alias "$endpoint" "$access" "$secret"; then
    S3_ENDPOINT="$endpoint"; save_config
    echo "Saved credentials to mc alias '$S3_ALIAS' (~/.mc/config.json)."
  else
    echo "Failed to register the mc alias. Check the endpoint and keys." >&2; return 1
  fi
}

cmd_s3_test() {
  have_mc || { echo "mc not found: $MC" >&2; return 1; }
  mc_alias_configured || { echo "Alias '$S3_ALIAS' not configured (ijsi s3 login)." >&2; return 1; }
  echo "Listing $S3_ALIAS ..."
  if "$MC" ls "$S3_ALIAS"; then echo "Connection OK."; else
    echo "Could not reach $S3_ALIAS. Check endpoint/keys." >&2; return 1
  fi
}

s3_status() {
  printf 'mc client:         %s\n' "$(have_mc && command -v "$MC" || echo "not found: $MC")"
  printf 'mc alias:          %s  (%s)\n' "$S3_ALIAS" "$(mc_alias_label)"
  printf 'Endpoint:          %s\n' "${S3_ENDPOINT:-<unset>}"
  printf 'Bucket:            %s\n' "${S3_BUCKET:-<unset>}"
  printf 'Prefix:            %s\n' "${S3_PREFIX:-<none>}"
  printf 'Upload target:     %s\n' "$(s3_target)"
  printf 'Public base URL:   %s\n' "$(s3_public_base_url)"
  if s3_preflight >/dev/null; then
    printf 'Readiness:         READY\n'
  else
    printf 'Readiness:         NOT READY\n'; s3_preflight | sed 's/^/  - /'
  fi
  [[ -f "$STATE_DIR/.needs_upload" ]] && printf 'Pending upload:    YES (previous upload incomplete; next refresh/sync retries)\n'
  return 0
}

cmd_s3() {
  case "${1:-status}" in
    status)        s3_status ;;
    login)         cmd_s3_login ;;
    setup)         cmd_s3_setup ;;
    sync|publish)  s3_publish && rm -f "$STATE_DIR/.needs_upload" ;;
    test)          cmd_s3_test ;;
    -h|--help|"")  echo "usage: ijsi s3 [status|login|setup|sync|test]" ;;
    *)             echo "s3: unknown subcommand: $1" >&2
                   echo "usage: ijsi s3 [status|login|setup|sync|test]" >&2; return 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# Locking
# ---------------------------------------------------------------------------

# Runs "$@" while holding a non-blocking refresh lock. Returns 100 if busy.
with_refresh_lock() {
  ensure_dirs
  # Without flock we cannot serialise; run anyway rather than falsely report "busy".
  if ! command -v flock >/dev/null 2>&1; then
    echo "Note: flock not found - running without a concurrency lock." >&2
    "$@"; return $?
  fi
  local lockfd
  exec {lockfd}>"$CACHE_DIR/refresh.lock" || return 1
  if ! flock -n "$lockfd"; then
    exec {lockfd}>&-; return 100
  fi
  "$@"
  local rc=$?
  flock -u "$lockfd"
  exec {lockfd}>&-
  return $rc
}

# ---------------------------------------------------------------------------
# refresh
# ---------------------------------------------------------------------------

do_refresh_cli() {
  local force="$1" only="$2" no_upload="$3"
  local n_idx=0 n_up=0 n_skip=0 n_fail=0 total=0 repo
  local IJSI_FORCE="$force"   # visible to index_repo via bash dynamic scope

  while IFS= read -r repo; do
    [[ -z "$repo" ]] && continue
    if [[ -n "$only" ]] && ! match_only "$repo" "$only"; then continue; fi
    total=$((total + 1))
    index_repo "$repo"
    case $? in
      3) n_idx=$((n_idx + 1)) ;;
      0) n_up=$((n_up + 1)) ;;
      4) n_skip=$((n_skip + 1)) ;;
      *) n_fail=$((n_fail + 1)) ;;
    esac
  done < <(iter_repos)

  local upload_note=""
  if [[ -z "$no_upload" ]] && { [[ $n_idx -gt 0 ]] || [[ -f "$STATE_DIR/.needs_upload" ]]; }; then
    echo
    if s3_publish; then
      upload_note="ok"; rm -f "$STATE_DIR/.needs_upload"
    else
      upload_note="FAILED"; n_fail=$((n_fail + 1))
    fi
  fi

  printf '\n%sSummary%s  indexed=%d  up-to-date=%d  skipped=%d  failed=%d  (of %d)' \
    "$C_BOLD" "$C_RESET" "$n_idx" "$n_up" "$n_skip" "$n_fail" "$total"
  [[ -n "$upload_note" ]] && printf '  upload=%s' "$upload_note"
  printf '\n'
  [[ $n_fail -gt 0 ]] && return 1 || return 0
}

cmd_refresh() {
  local force="" only="" no_upload=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--force)   force="1" ;;
      --only)       shift; only="${1:-}" ;;
      --only=*)     only="${1#*=}" ;;
      --no-upload)  no_upload="1" ;;
      -h|--help)    echo "usage: ijsi refresh [--force] [--only name,name,...] [--no-upload]"; return 0 ;;
      *)            echo "refresh: unknown argument: $1" >&2; return 1 ;;
    esac
    shift
  done

  if ! have_cli; then
    echo "Missing CLI: $CLI" >&2
    echo "Install ij-shared-indexes-tool-cli and ensure it is on PATH (or set IJSI_CLI)." >&2
    return 1
  fi
  if ! have_composer; then
    echo "Missing composer: $COMPOSER" >&2
    echo "Install Composer and ensure it is on PATH (or set IJSI_COMPOSER)." >&2
    return 1
  fi
  if [[ -z "$no_upload" ]]; then
    local probs line
    if ! probs="$(s3_preflight)"; then
      echo "MinIO upload is not ready:" >&2
      while IFS= read -r line; do echo "  - $line" >&2; done <<< "$probs"
      echo "Fix it in the TUI (MinIO settings), run: ijsi s3 setup, or use --no-upload to index only." >&2
      return 1
    fi
  fi

  with_refresh_lock do_refresh_cli "$force" "$only" "$no_upload"
  local rc=$?
  if [[ $rc -eq 100 ]]; then
    echo "Another ijsi refresh is already running. Skipping." >&2; return 0
  fi
  return $rc
}

