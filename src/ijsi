# ---------------------------------------------------------------------------
# systemd (user) - optional local test server only (no refresh timer)
# ---------------------------------------------------------------------------

server_state() { local s; s="$(systemctl --user is-active ij-shared-indexes-server.service 2>/dev/null)"; printf '%s' "${s:-unknown}"; }

cmd_install_systemd() {
  mkdir -p "$SYSTEMD_DIR"

  # Bake an absolute CLI path and the config path into the unit: systemd --user
  # services run with a stripped PATH, so the bare CLI name would not resolve.
  local cli_abs
  cli_abs="$(command -v "$CLI" 2>/dev/null || printf '%s' "$CLI")"

  cat > "$SYSTEMD_DIR/ij-shared-indexes-server.service" <<EOF
[Unit]
Description=JetBrains Shared Indexes Local Test Server
After=default.target
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
Environment=IJSI_CLI=$cli_abs
Environment=IJSI_CONFIG=$CONFIG_FILE
ExecStart=$SELF server
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
EOF

  systemctl --user daemon-reload
  systemctl --user enable --now ij-shared-indexes-server.service
  echo "Installed and enabled the local test-server service."
  echo "(With MinIO upload enabled you usually don't need this - indexes are hosted on the bucket.)"
}

cmd_uninstall_systemd() {
  systemctl --user disable --now ij-shared-indexes-server.service 2>/dev/null || true
  # Also remove legacy refresh units from older ijsi versions, if present.
  systemctl --user disable --now ij-shared-indexes-refresh.timer 2>/dev/null || true
  rm -f "$SYSTEMD_DIR/ij-shared-indexes-server.service" \
        "$SYSTEMD_DIR/ij-shared-indexes-refresh.service" \
        "$SYSTEMD_DIR/ij-shared-indexes-refresh.timer"
  systemctl --user daemon-reload
  echo "Removed ijsi systemd user services."
}

cmd_status() {
  systemctl --user status ij-shared-indexes-server.service --no-pager 2>&1
}

cmd_server_logs() { journalctl --user -u ij-shared-indexes-server.service -f; }

# Show the newest run log (no systemd journal involved any more).
cmd_logs() {
  local f
  f="$(ls -1t "$LOG_DIR"/*.log 2>/dev/null | head -1)"
  if [[ -z "$f" ]]; then
    echo "No logs in $LOG_DIR yet. Run: ijsi refresh"
    return 0
  fi
  echo "Newest log: $f"
  echo "----------------------------------------"
  cat "$f"
}

# ===========================================================================
# Terminal GUI (whiptail / dialog)
# ===========================================================================

TUI=""
detect_tui() {
  if   command -v whiptail >/dev/null 2>&1; then TUI=whiptail
  elif command -v dialog   >/dev/null 2>&1; then TUI=dialog
  else TUI=""; fi
}
detect_tui_name() {
  detect_tui
  [[ -n "$TUI" ]] && command -v "$TUI" || echo "none (install 'whiptail' or 'dialog')"
}

# whiptail/dialog wrappers. Both write the chosen value to stderr; the
# 3>&1 1>&2 2>&3 dance moves it to stdout so we can capture it.
tui_menu()      { local t="$1" x="$2"; shift 2; "$TUI" --title "$t" --menu      "$x" 21 78 12 "$@" 3>&1 1>&2 2>&3; }
tui_checklist() { local t="$1" x="$2"; shift 2; "$TUI" --separate-output --title "$t" --checklist "$x" 22 90 14 "$@" 3>&1 1>&2 2>&3; }
tui_input()     { local t="$1" x="$2" d="$3";   "$TUI" --title "$t" --inputbox  "$x" 10 78 "$d" 3>&1 1>&2 2>&3; }
tui_password()  { local t="$1" x="$2";          "$TUI" --title "$t" --passwordbox "$x" 10 78 3>&1 1>&2 2>&3; }
tui_yesno()     { local t="$1" x="$2";          "$TUI" --title "$t" --yesno     "$x" 12 78; }
tui_msg()       { local t="$1" x="$2";          "$TUI" --title "$t" --msgbox    "$x" 18 80; }
tui_textbox()   { local t="$1" f="$2";          "$TUI" --title "$t" --textbox   "$f" 26 100; }
tui_gauge()     { local t="$1";                 "$TUI" --title "$t" --gauge "Starting..." 8 74 0; }

tui_main() {
  detect_tui
  if [[ -z "$TUI" ]]; then
    echo "The terminal GUI needs 'whiptail' (package: newt) or 'dialog'." >&2
    echo "Install one, e.g.:  sudo apt install whiptail   (or: sudo pacman -S newt)" >&2
    echo >&2
    usage
    return 1
  fi

  ensure_dirs
  save_config_if_missing

  local choice header
  while true; do
    header="$(printf 'Local JetBrains shared-index manager (v%s)\n\nUpload: %s    mc alias: %s\nPublic URL: %s\nProjects: %s    Config: %s\n\nChoose an action:' \
      "$IJSI_VERSION" "$(s3_state_label)" "$(mc_alias_label)" "$(s3_public_base_url)" "$(count_projects)" "$CONFIG_FILE")"

    choice="$(tui_menu "ijsi" "$header" \
      refresh "Refresh / index changed projects (+ upload)" \
      select  "Pick specific projects to index" \
      force   "Force re-index everything (ignore cache)" \
      minio   "MinIO / S3 upload settings & credentials" \
      boost   "Evaluate speedup on one project (boost)" \
      config  "Configure IDEs, roots, port" \
      server  "Local test server & systemd" \
      status  "Status & health check" \
      logs    "View logs" \
      maint   "Maintenance (reset / prune / clear / re-sync)" \
      quit    "Quit")" || break

    case "$choice" in
      refresh) tui_run_refresh "" "$(iter_projects)" ;;
      select)  tui_select_refresh ;;
      force)   tui_yesno "Force re-index" "Re-index ALL projects, ignoring the cache?\nThis can take a while." \
                 && tui_run_refresh "1" "$(iter_projects)" ;;
      minio)   tui_minio_menu ;;
      boost)   tui_boost ;;
      config)  tui_config_menu ;;
      server)  tui_server_menu ;;
      status)  tui_show_status ;;
      logs)    tui_logs_menu ;;
      maint)   tui_maint_menu ;;
      quit|"") break ;;
    esac
  done
  clear 2>/dev/null || true
}

# Drives index_project across a newline-separated project list, showing a gauge,
# then uploads to MinIO (if enabled and anything was indexed).
tui_run_refresh() {
  local force="$1" project_list="$2"
  local -a projects=()
  local p
  while IFS= read -r p; do [[ -n "$p" ]] && projects+=( "$p" ); done <<< "$project_list"

  local total=${#projects[@]}
  if [[ $total -eq 0 ]]; then tui_msg "Refresh" "No projects to index."; return; fi

  if ! have_cli; then
    tui_msg "Refresh" "Missing CLI: $CLI\n\nInstall ij-shared-indexes-tool-cli and ensure it is on PATH, or set IJSI_CLI in the config."
    return
  fi

  if [[ "$S3_ENABLED" == "yes" ]]; then
    local probs
    if ! probs="$(s3_preflight)"; then
      tui_msg "Refresh" "MinIO upload is ON but not ready:\n\n$probs\n\nConfigure it under 'MinIO / S3 upload settings', or disable upload."
      return
    fi
  fi

  ensure_dirs
  local lockfd
  exec {lockfd}>"$CACHE_DIR/refresh.lock" || { tui_msg "Refresh" "Cannot open lock file."; return; }
  if ! flock -n "$lockfd"; then
    exec {lockfd}>&-
    tui_msg "Refresh" "Another refresh is already running (another window)."
    return
  fi

  local results runlog
  results="$(mktemp)"
  runlog="$LOG_DIR/refresh-$(date +%Y%m%d-%H%M%S).log"

  {
    local i=0 name pct
    local IJSI_RESULTS="$results"
    local IJSI_FORCE="$force"
    for p in "${projects[@]}"; do
      name="$(basename "$p")"
      pct=$(( i * 100 / total ))
      printf 'XXX\n%d\nIndexing %s   (%d of %d)\nXXX\n' "$pct" "$name" "$((i + 1))" "$total"
      index_project "$p" >> "$runlog" 2>&1
      i=$((i + 1))
    done
    printf 'XXX\n100\nFinished.\nXXX\n'
  } | tui_gauge "Refreshing shared indexes"

  flock -u "$lockfd"
  exec {lockfd}>&-

  local n_idx n_up n_skip n_fail
  n_idx=$(grep -c '^indexed'  "$results" 2>/dev/null);  n_idx=${n_idx:-0}
  n_up=$(grep  -c '^uptodate' "$results" 2>/dev/null);  n_up=${n_up:-0}
  n_skip=$(grep -c '^skipped' "$results" 2>/dev/null);  n_skip=${n_skip:-0}
  n_fail=$(grep -c '^failed'  "$results" 2>/dev/null);  n_fail=${n_fail:-0}
  rm -f "$results"

  local upload_line=""
  if [[ "$S3_ENABLED" == "yes" ]] && { [[ "$n_idx" -gt 0 ]] || [[ -f "$STATE_DIR/.needs_upload" ]]; }; then
    if s3_publish >> "$runlog" 2>&1; then
      upload_line="$(printf '\nUploaded to: %s' "$(s3_public_base_url)")"
      rm -f "$STATE_DIR/.needs_upload"
    else
      upload_line="$(printf '\nUPLOAD FAILED - see log')"
    fi
  fi

  local summary
  summary="$(printf 'Indexed:     %s\nUp to date:  %s\nSkipped:     %s\nFailed:      %s%s\n\nLog: %s' \
    "$n_idx" "$n_up" "$n_skip" "$n_fail" "$upload_line" "$runlog")"
  tui_msg "Refresh complete" "$summary"

  if [[ "$n_fail" -gt 0 ]] && tui_yesno "Refresh" "Some projects failed. View the log now?"; then
    tui_textbox "Refresh log" "$runlog"
  fi
}

tui_select_refresh() {
  local -a plist=() items=()
  local p k
  while IFS= read -r p; do [[ -n "$p" ]] && plist+=( "$p" ); done < <(iter_projects)

  if [[ ${#plist[@]} -eq 0 ]]; then tui_msg "Select projects" "No projects found."; return; fi

  for p in "${plist[@]}"; do
    k="$(project_kind "$p")"
    items+=( "$p" "[$k] $(basename "$p")" "off" )
  done

  local chosen
  # --separate-output (set in tui_checklist) makes whiptail print the chosen tags
  # one per line, unquoted, so we pass them straight through instead of eval-parsing
  # its output (which would execute metacharacters in project paths).
  chosen="$(tui_checklist "Select projects" "Space toggles, Enter confirms. Selected projects will be indexed." "${items[@]}")" || return
  [[ -z "$chosen" ]] && { tui_msg "Select projects" "Nothing selected."; return; }

  tui_run_refresh "" "$chosen"
}

tui_boost() {
  local -a plist=() items=()
  local p k proj
  while IFS= read -r p; do [[ -n "$p" ]] && plist+=( "$p" ); done < <(iter_projects)
  if [[ ${#plist[@]} -eq 0 ]]; then tui_msg "Boost" "No projects found."; return; fi
  for p in "${plist[@]}"; do k="$(project_kind "$p")"; items+=( "$p" "[$k] $(basename "$p")" ); done

  proj="$(tui_menu "Boost - evaluate speedup" "Pick a project to measure the shared-index speedup (with vs. without):" "${items[@]}")" || return
  [[ -z "$proj" ]] && return

  clear 2>/dev/null || true
  local out; out="$(mktemp)"
  cmd_boost "$proj" 2>&1 | tee "$out"
  echo; echo "Press Enter to return to the menu..."; read -r _ || true
  tui_textbox "Boost result" "$out"
  rm -f "$out"
}

tui_minio_menu() {
  local choice
  while true; do
    choice="$(tui_menu "MinIO / S3 upload" \
      "$(printf 'Endpoint: %s   Alias: %s (%s)\nBucket: %s   Prefix: %s\nPublic URL: %s\nUpload: %s' \
          "${S3_ENDPOINT:-<unset>}" "$S3_ALIAS" "$(mc_alias_label)" \
          "${S3_BUCKET:-<unset>}" "${S3_PREFIX:-<none>}" \
          "$(s3_public_base_url)" "$(s3_state_label)")" \
      creds   "Set credentials (endpoint / access / secret)" \
      bucket  "Set bucket name              (${S3_BUCKET:-unset})" \
      prefix  "Set path prefix              (${S3_PREFIX:-none})" \
      url     "Override public base URL     (${PUBLIC_BASE_URL:-auto})" \
      toggle  "Enable / disable upload      ($(s3_state_label))" \
      setup   "Create bucket + make public (anonymous download)" \
      test    "Test connection" \
      sync    "Re-upload local indexes now" \
      status  "Show resolved S3 status" \
      back    "Back")" || return

    case "$choice" in
      creds)  tui_minio_creds ;;
      bucket) local v; v="$(tui_input "Bucket" "S3 bucket name for shared indexes:" "$S3_BUCKET")" \
                && { S3_BUCKET="$v"; BASE_URL="$(effective_base_url)"; save_config; } ;;
      prefix) local v; v="$(tui_input "Prefix" "Optional path prefix inside the bucket (blank = none):" "$S3_PREFIX")" \
                && { S3_PREFIX="$v"; BASE_URL="$(effective_base_url)"; save_config; } ;;
      url)    local v; v="$(tui_input "Public base URL" "Override the public download URL the IDE uses.\nLeave blank to derive from endpoint + bucket + prefix:" "$PUBLIC_BASE_URL")" \
                && { PUBLIC_BASE_URL="$v"; BASE_URL="$(effective_base_url)"; save_config; } ;;
      toggle) if [[ "$S3_ENABLED" == "yes" ]]; then S3_ENABLED="no"; else S3_ENABLED="yes"; fi
              BASE_URL="$(effective_base_url)"; save_config
              tui_msg "Upload" "Upload is now: $(s3_state_label)\nBase-url: $BASE_URL" ;;
      setup)  local t; t="$(mktemp)"; cmd_s3_setup >"$t" 2>&1; tui_textbox "Bucket setup" "$t"; rm -f "$t" ;;
      test)   local t; t="$(mktemp)"; cmd_s3_test  >"$t" 2>&1; tui_textbox "Connection test" "$t"; rm -f "$t" ;;
      sync)   local t; t="$(mktemp)"; s3_publish >"$t" 2>&1 && rm -f "$STATE_DIR/.needs_upload"; tui_textbox "Re-upload" "$t"; rm -f "$t" ;;
      status) local t; t="$(mktemp)"; s3_status    >"$t" 2>&1; tui_textbox "S3 status" "$t"; rm -f "$t" ;;
      back|"") return ;;
    esac
  done
}

tui_minio_creds() {
  local endpoint access secret
  endpoint="$(tui_input "MinIO endpoint" "S3 API endpoint URL (e.g. https://minio.example.com:9000):" "$S3_ENDPOINT")" || return
  [[ -z "$endpoint" ]] && { tui_msg "Credentials" "Endpoint is required."; return; }
  access="$(tui_input "Access key" "MinIO/S3 access key:" "")" || return
  secret="$(tui_password "Secret key" "MinIO/S3 secret key (input hidden):")" || return
  if [[ -z "$access" || -z "$secret" ]]; then tui_msg "Credentials" "Access key and secret key are both required."; return; fi
  if ! have_mc; then
    tui_msg "Credentials" "mc (MinIO Client) not found: $MC\n\nInstall it (or set MC in the config), then retry."
    return
  fi
  if mc_set_alias "$endpoint" "$access" "$secret"; then
    S3_ENDPOINT="$endpoint"; BASE_URL="$(effective_base_url)"; save_config
    tui_msg "Credentials" "Saved to mc alias '$S3_ALIAS' (~/.mc/config.json).\n\nThe secret key is NOT stored in ijsi's config.\n\nNext: set a bucket, then 'Create bucket + make public'."
  else
    tui_msg "Credentials" "Failed to register the mc alias '$S3_ALIAS'.\nCheck the endpoint URL and keys, then retry."
  fi
}

tui_config_menu() {
  local choice
  while true; do
    choice="$(tui_menu "Configure" "Settings are saved to:\n$CONFIG_FILE\n\n(IJSI_* environment variables override the file.)" \
      port     "Server port                ($PORT)" \
      roots    "Project root folders       (${#PROJECT_ROOTS[@]})" \
      ides     "IDE install locations" \
      toolbox  "Toolbox apps folder" \
      cli      "shared-indexes CLI         ($CLI)" \
      mc       "mc (MinIO Client) command  ($MC)" \
      view     "View resolved configuration" \
      edit     "Open config file in \$EDITOR" \
      back     "Back")" || return

    case "$choice" in
      port)     local v; v="$(tui_input "Server port" "TCP port for the local test server:" "$PORT")" \
                  && [[ "$v" =~ ^[0-9]+$ ]] && { PORT="$v"; BASE_URL="$(effective_base_url)"; save_config; } ;;
      roots)    tui_roots_menu ;;
      ides)     tui_ides_menu ;;
      toolbox)  local v; v="$(tui_input "Toolbox apps" "Folder containing JetBrains Toolbox app installs:" "$TOOLBOX_APPS")" \
                  && [[ -n "$v" ]] && { TOOLBOX_APPS="$v"; apply_env_and_defaults; save_config; } ;;
      cli)      local v; v="$(tui_input "CLI" "shared-indexes CLI command or path:" "$CLI")" \
                  && [[ -n "$v" ]] && { CLI="$v"; save_config; } ;;
      mc)       local v; v="$(tui_input "mc" "MinIO Client command or path:" "$MC")" \
                  && [[ -n "$v" ]] && { MC="$v"; save_config; } ;;
      view)     local t; t="$(mktemp)"; print_resolved_config > "$t"; tui_textbox "Resolved configuration" "$t"; rm -f "$t" ;;
      edit)     save_config; clear 2>/dev/null || true; "${EDITOR:-vi}" "$CONFIG_FILE"; load_config; apply_env_and_defaults ;;
      back|"")  return ;;
    esac
  done
}

tui_roots_menu() {
  local choice
  while true; do
    local -a items=()
    local r idx=0
    for r in "${PROJECT_ROOTS[@]}"; do items+=( "$idx" "$r" ); idx=$((idx + 1)); done
    items+=( "add" "+ Add a project root..." )
    items+=( "back" "Back" )

    choice="$(tui_menu "Project roots" "Select a root to remove, or add a new one:" "${items[@]}")" || return
    case "$choice" in
      add)  local v; v="$(tui_input "Add project root" "Path to a folder containing project directories:" "$HOME/")" \
              && [[ -n "$v" ]] && { PROJECT_ROOTS+=( "$v" ); save_config; } ;;
      back|"") return ;;
      *)    if tui_yesno "Remove root" "Remove this project root?\n\n${PROJECT_ROOTS[$choice]}"; then
              unset 'PROJECT_ROOTS[$choice]'
              PROJECT_ROOTS=( "${PROJECT_ROOTS[@]}" )
              save_config
            fi ;;
    esac
  done
}

tui_ides_menu() {
  local choice
  while true; do
    choice="$(tui_menu "IDE locations" "Set each IDE to 'auto' (detect from Toolbox) or an absolute install dir." \
      phpstorm "PhpStorm   ($PHPSTORM_IDE)" \
      webstorm "WebStorm   ($WEBSTORM_IDE)" \
      datagrip "DataGrip   ($DATAGRIP_IDE)" \
      goland   "GoLand     ($GOLAND_IDE)" \
      back     "Back")" || return

    local var cur
    case "$choice" in
      phpstorm) var=PHPSTORM_IDE; cur="$PHPSTORM_IDE" ;;
      webstorm) var=WEBSTORM_IDE; cur="$WEBSTORM_IDE" ;;
      datagrip) var=DATAGRIP_IDE; cur="$DATAGRIP_IDE" ;;
      goland)   var=GOLAND_IDE;   cur="$GOLAND_IDE" ;;
      back|"")  return ;;
    esac

    local v
    v="$(tui_input "$choice" "'auto' to detect, or an absolute IDE install dir:" "$cur")" || continue
    [[ -z "$v" ]] && continue
    printf -v "$var" '%s' "$v"
    apply_env_and_defaults
    save_config
  done
}

tui_server_menu() {
  local choice
  while true; do
    choice="$(tui_menu "Local test server & systemd" \
      "$(printf 'The local server hosts indexes at http://127.0.0.1:%s for testing\nwhen MinIO upload is off. Service state: %s' "$PORT" "$(server_state)")" \
      install   "Install + enable the local server service" \
      uninstall "Uninstall the server service" \
      restart   "Restart the server service" \
      back      "Back")" || return

    case "$choice" in
      install)   local t; t="$(mktemp)"; cmd_install_systemd > "$t" 2>&1; tui_textbox "Install" "$t"; rm -f "$t" ;;
      uninstall) tui_yesno "Uninstall" "Remove the systemd user service(s)?" \
                   && { local t; t="$(mktemp)"; cmd_uninstall_systemd > "$t" 2>&1; tui_textbox "Uninstall" "$t"; rm -f "$t"; } ;;
      restart)   systemctl --user restart ij-shared-indexes-server.service 2>/dev/null; tui_msg "Server" "Restart requested.\nState: $(server_state)" ;;
