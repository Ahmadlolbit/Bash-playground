tui_show_status() {
  local t; t="$(mktemp)"
  { cmd_check; echo; echo "----- MinIO / S3 -----"; s3_status; echo; echo "----- systemd -----"; cmd_status; } > "$t" 2>&1
  tui_textbox "Status & health" "$t"
  rm -f "$t"
}

tui_logs_menu() {
  local choice
  while true; do
    local -a items=()
    local f n=0
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      items+=( "$f" "$(basename "$f")" )
      n=$((n + 1))
    done < <(ls -1t "$LOG_DIR"/*.log 2>/dev/null | head -n 25)

    if [[ $n -eq 0 ]]; then tui_msg "Logs" "No logs yet. Run a refresh first."; return; fi
    items+=( "back" "Back" )

    choice="$(tui_menu "Logs" "Most recent log files in:\n$LOG_DIR" "${items[@]}")" || return
    [[ "$choice" == "back" || -z "$choice" ]] && return
    tui_textbox "$(basename "$choice")" "$choice"
  done
}

tui_maint_menu() {
  local choice
  while true; do
    choice="$(tui_menu "Maintenance" "Cache: $CACHE_DIR" \
      reset  "Reset fingerprints (force recheck next refresh)" \
      sync   "Re-upload local indexes to MinIO" \
      prune  "Prune old log files (keep newest 100)" \
      clear  "Clear ENTIRE shared-index cache" \
      back   "Back")" || return

    case "$choice" in
      reset)  tui_yesno "Reset state" "Forget all fingerprints?\nThe next refresh will recheck every project." \
                && { cmd_reset_state >/dev/null; tui_msg "Reset state" "Done. Next refresh rechecks all projects."; } ;;
      sync)   local t; t="$(mktemp)"; s3_publish > "$t" 2>&1 && rm -f "$STATE_DIR/.needs_upload"; tui_textbox "Re-upload to MinIO" "$t"; rm -f "$t" ;;
      prune)  local t; t="$(mktemp)"; cmd_prune_logs 100 > "$t" 2>&1; tui_textbox "Prune logs" "$t"; rm -f "$t" ;;
      clear)  tui_yesno "Clear cache" "Delete the entire generated shared-index cache?\n\n$CACHE_DIR" \
                && { cmd_clear_cache >/dev/null; tui_msg "Clear cache" "Cache cleared."; } ;;
      back|"") return ;;
    esac
  done
}

# ---------------------------------------------------------------------------
# Usage / dispatch
# ---------------------------------------------------------------------------

usage() {
  cat <<EOF
ijsi $IJSI_VERSION - JetBrains shared-index manager (MinIO/S3)

Run with no arguments to open the terminal GUI.

Commands:
  (no args)         Open the terminal GUI (whiptail/dialog)
  tui               Open the terminal GUI explicitly
  refresh [opts]    Index new/changed projects, then upload to MinIO
                      --force            re-index even if unchanged
                      --only a,b,c       only projects whose name/path matches
  s3 <sub>          MinIO/S3:  status | login | setup | sync | test | enable | disable
  sync              Re-upload the local indexes to MinIO (no re-indexing)
  boost <project>   Measure analysis-time speedup with vs. without indexes
  list              List detected projects and their IDE
  check | doctor    Show detected IDEs, CLI, roots, MinIO + server status
  server            Start the local test HTTP server (foreground)
  status            Show the local server systemd service status
  logs              Show the newest refresh log
  server-logs       Follow server logs (journalctl)
  install-systemd   Install + enable the local test-server service
  uninstall-systemd Remove ijsi systemd user services
  config [sub]      show | path | init | edit   (manage $CONFIG_FILE)
  reset-state [p]   Forget fingerprints (all, or one project) so they re-index
  clear-cache       Delete the generated shared-index cache
  prune-logs [N]    Keep newest N logs (default 100), delete the rest
  version           Print ijsi + ij-shared-indexes-tool-cli version
  help              Show this help

MinIO quick start:
  1) ijsi s3 login              # endpoint + access/secret -> stored in mc
  2) set a bucket               # TUI: MinIO settings, or edit config S3_BUCKET
  3) ijsi s3 enable             # turn on upload
  4) ijsi s3 setup              # create bucket + grant anonymous download
  5) ijsi refresh               # index + upload; commit each intellij.yaml

Configuration precedence:  built-in defaults  <  $CONFIG_FILE  <  IJSI_* env
EOF
}

main() {
  load_config
  apply_env_and_defaults

  case "${1:-}" in
    ""|tui|menu|ui)     shift 2>/dev/null || true; tui_main ;;
    refresh)            shift; cmd_refresh "$@" ;;
    s3)                 shift; cmd_s3 "$@" ;;
    sync|publish)       s3_publish && rm -f "$STATE_DIR/.needs_upload" ;;
    boost|evaluate)     shift; cmd_boost "$@" ;;
    list)               cmd_list ;;
    check|doctor)       cmd_check ;;
    server)             cmd_server ;;
    status)             cmd_status ;;
    logs)               cmd_logs ;;
    server-logs)        cmd_server_logs ;;
    install-systemd)    cmd_install_systemd ;;
    uninstall-systemd)  cmd_uninstall_systemd ;;
    config)             shift; cmd_config "$@" ;;
    reset-state)        shift; cmd_reset_state "$@" ;;
    clear-cache)        cmd_clear_cache ;;
    prune-logs)         shift; cmd_prune_logs "$@" ;;
    version|-V|--version) cmd_version ;;
    -h|--help|help)     usage ;;
    *)
      echo "Unknown command: $1" >&2
      echo >&2
      usage
      exit 1
      ;;
  esac
}

# Only run when executed directly (allows sourcing for tests/reuse).
if [[ "${BASH_SOURCE[0]:-$0}" == "${0}" ]]; then
  main "$@"
fi
